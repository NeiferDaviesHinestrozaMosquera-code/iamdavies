---
import type { Project } from '../../lib/supabase';
import { getImage } from 'astro:assets';

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;

const formatUrl = (url: string | null) => {
  if (!url) return '';
  const trimmed = url.trim();
  if (!trimmed) return '';
  if (/^(https?:\/\/|mailto:|tel:|javascript:)/i.test(trimmed)) {
    return trimmed;
  }
  return `https://${trimmed}`;
};

const formattedLiveUrl = formatUrl(project.live_url);
const formattedGithubUrl = formatUrl(project.github_url);

// Optimize main image (if present)
let optimizedMainUrl = '';
if (project.image_url) {
  try {
    const opt = await getImage({ src: project.image_url, width: 800, height: 450, format: 'webp' });
    optimizedMainUrl = opt.src;
  } catch (e) {
    console.error('Error optimizing project.image_url:', e);
    optimizedMainUrl = project.image_url;
  }
}

// Optimize multiple carousel images
let optimizedCarouselUrls: string[] = [];
if (project.images_urls && project.images_urls.length > 0) {
  optimizedCarouselUrls = await Promise.all(
    project.images_urls.map(async (url) => {
      try {
        const opt = await getImage({ src: url, width: 800, height: 450, format: 'webp' });
        return opt.src;
      } catch (e) {
        console.error('Error optimizing carousel image:', url, e);
        return url;
      }
    })
  );
}

const catFilterVal = project.category ? project.category.toLowerCase().replace(/\s+/g, '-') : 'general';
const animationDelayClass = index % 3 === 0 ? 'delay-1' : index % 3 === 1 ? 'delay-2' : 'delay-3';
const initials = project.title.split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase();
---

<div class={`project-card glass reveal-scale ${animationDelayClass}`} data-category={catFilterVal}>
  <div class="project-visual">
    {optimizedCarouselUrls && optimizedCarouselUrls.length > 1 ? (
      <div class="carousel-container" data-carousel>
        <div class="carousel-track">
          {optimizedCarouselUrls.map((imgUrl, i) => (
            i === 0 ? (
              <img src={imgUrl} alt={`${project.title} image ${i+1}`} class="project-img-display carousel-slide" />
            ) : (
              <img data-src={imgUrl} alt={`${project.title} image ${i+1}`} class="project-img-display carousel-slide" />
            )
          ))}
        </div>
        <button class="carousel-btn prev-btn" aria-label="Previous image">‹</button>
        <button class="carousel-btn next-btn" aria-label="Next image">›</button>
        <div class="carousel-dots">
          {optimizedCarouselUrls.map((_, i) => (
            <span class={`carousel-dot ${i === 0 ? 'active' : ''}`} data-index={i}></span>
          ))}
        </div>
      </div>
    ) : optimizedCarouselUrls && optimizedCarouselUrls.length === 1 ? (
      <img src={optimizedCarouselUrls[0]} alt={project.title} class="project-img-display" />
    ) : optimizedMainUrl ? (
      <img src={optimizedMainUrl} alt={project.title} class="project-img-display" />
    ) : (
      <div class="project-placeholder-gradient">
        <span class="placeholder-icon">🚀</span>
      </div>
    )}
  </div>
  <div class="project-meta">
    <h3>{project.title}</h3>
    <p>{project.description}</p>
    {project.tags && project.tags.length > 0 && (
      <div class="project-tags">
        {project.tags.map(tag => (
          <span>{tag}</span>
        ))}
      </div>
    )}
    
    {(formattedLiveUrl || formattedGithubUrl) && (
      <div class="project-links-row" style="display: none;">
        {formattedLiveUrl && (
          <a href={formattedLiveUrl} target="_blank" rel="noopener noreferrer" class="proj-link-item">
            Demo
          </a>
        )}
        {formattedGithubUrl && (
          <a href={formattedGithubUrl} target="_blank" rel="noopener noreferrer" class="proj-link-item">
            GitHub
          </a>
        )}
      </div>
    )}
  </div>
</div>

<style>
  /* 3D Glass Card styling */
  .project-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    transform-style: preserve-3d;
    transform: perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1);
    transition: transform 0.1s ease-out, border-color var(--transition-normal), box-shadow var(--transition-normal);
    position: relative;
    border: 1px solid rgba(255, 255, 255, 0.05);
    cursor: pointer;
  }

  .project-card:hover {
    border-color: rgba(6, 182, 212, 0.3);
    box-shadow: 0 25px 50px -15px rgba(0, 0, 0, 0.6),
                0 0 35px -5px rgba(139, 92, 246, 0.15);
  }

  .project-visual {
    width: 100%;
    aspect-ratio: 16 / 9;
    position: relative;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
    background: #000;
  }

  /* Carousel and display styles made global so the modal can reuse them cleanly */
  :global(.project-img-display) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-normal);
  }

  .project-card:hover :global(.project-img-display:not(.carousel-slide)) {
    transform: scale(1.05);
  }

  /* Carousel global classes */
  :global(.carousel-container) {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }
  :global(.carousel-track) {
    display: flex;
    width: 100%;
    height: 100%;
    transition: transform 0.4s ease-in-out;
  }
  :global(.carousel-slide) {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  :global(.carousel-btn) {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0,0,0,0.5);
    color: white;
    border: none;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s, background 0.2s;
    font-size: 18px;
    z-index: 2;
  }
  :global(.carousel-container:hover .carousel-btn) {
    opacity: 1;
  }
  :global(.carousel-btn:hover) {
    background: rgba(6, 182, 212, 0.8);
  }
  :global(.prev-btn) { left: 8px; }
  :global(.next-btn) { right: 8px; }
  
  :global(.carousel-dots) {
    position: absolute;
    bottom: 12px;
    left: 0;
    width: 100%;
    display: flex;
    justify-content: center;
    gap: 6px;
    z-index: 2;
  }
  :global(.carousel-dot) {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.4);
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
  }
  :global(.carousel-dot.active) {
    background: var(--accent-cyan);
    transform: scale(1.2);
  }

  .project-placeholder-gradient {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.15), rgba(6, 182, 212, 0.15));
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .placeholder-icon {
    font-size: 3rem;
    filter: drop-shadow(0 0 10px rgba(6, 182, 212, 0.5));
  }

  /* Info section */
  .project-meta {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex-grow: 1;
    z-index: 3;
  }

  .project-meta h3 {
    font-size: 1.25rem;
    margin: 0;
    color: #fff;
  }

  .project-meta p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0 0 1rem 0;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: auto;
  }

  .project-tags span {
    font-size: 0.75rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border-color);
    padding: 0.25rem 0.6rem;
    border-radius: 6px;
    color: var(--text-secondary);
  }
</style>

<script>
  // Dynamic 3D tilt interaction for cards
  function setupCardTilt() {
    const cards = document.querySelectorAll('.project-card');
    
    cards.forEach(card => {
      const cardEl = card as HTMLElement;
      
      cardEl.addEventListener('mousemove', (e) => {
        const rect = cardEl.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const w = rect.width;
        const h = rect.height;
        
        const dx = (x / w) - 0.5;
        const dy = (y / h) - 0.5;
        
        cardEl.style.transform = `perspective(1000px) rotateX(${dy * -12}deg) rotateY(${dx * 12}deg) scale3d(1.02, 1.02, 1.02)`;
        cardEl.style.setProperty('--x', `${x}px`);
        cardEl.style.setProperty('--y', `${y}px`);
      });
      
      cardEl.addEventListener('mouseleave', () => {
        cardEl.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)';
      });
    });
  }

  // Carousel logic
  function setupCarousels(root: Document | HTMLElement = document) {
    const carousels = root.querySelectorAll('[data-carousel]');
    
    carousels.forEach(carousel => {
      const track = carousel.querySelector('.carousel-track') as HTMLElement;
      const slides = carousel.querySelectorAll('.carousel-slide');
      const nextBtn = carousel.querySelector('.next-btn');
      const prevBtn = carousel.querySelector('.prev-btn');
      const dots = carousel.querySelectorAll('.carousel-dot');
      
      if (!track || slides.length === 0) return;
      
      let currentIndex = 0;
      let autoPlayInterval: number;
      
      const loadLazyImages = () => {
        slides.forEach(slide => {
          const img = slide as HTMLImageElement;
          if (img.dataset.src) {
            img.src = img.dataset.src;
            img.removeAttribute('data-src');
          }
        });
      };
      
      const updateCarousel = () => {
        if (currentIndex > 0) {
          loadLazyImages();
        }
        track.style.transform = `translateX(-${currentIndex * 100}%)`;
        dots.forEach((dot, idx) => {
          dot.classList.toggle('active', idx === currentIndex);
        });
      };
      
      const nextSlide = () => {
        currentIndex = (currentIndex + 1) % slides.length;
        updateCarousel();
      };
      
      const prevSlide = () => {
        currentIndex = (currentIndex - 1 + slides.length) % slides.length;
        updateCarousel();
      };

      const startAutoPlay = () => {
        stopAutoPlay();
        autoPlayInterval = window.setInterval(nextSlide, 4000);
      };

      const stopAutoPlay = () => {
        if (autoPlayInterval) clearInterval(autoPlayInterval);
      };
      
      nextBtn?.addEventListener('click', (e) => {
        e.preventDefault(); e.stopPropagation();
        loadLazyImages();
        nextSlide(); startAutoPlay();
      });
      
      prevBtn?.addEventListener('click', (e) => {
        e.preventDefault(); e.stopPropagation();
        loadLazyImages();
        prevSlide(); startAutoPlay();
      });
      
      dots.forEach((dot, idx) => {
        dot.addEventListener('click', (e) => {
          e.preventDefault(); e.stopPropagation();
          loadLazyImages();
          currentIndex = idx;
          updateCarousel(); startAutoPlay();
        });
      });

      carousel.addEventListener('mouseenter', () => {
        loadLazyImages();
        stopAutoPlay();
      });
      carousel.addEventListener('mouseleave', startAutoPlay);
      carousel.addEventListener('touchstart', loadLazyImages, { passive: true });

      startAutoPlay();
    });
  }

  // Bind interactions on load
  function init() {
    setupCardTilt();
    setupCarousels();
  }

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('astro:page-load', init);
</script>
