---
interface Props {
  skills: string[];
  tools: string[];
  languages: any[];
}

const { skills = [], tools = [], languages = [] } = Astro.props;

const levelMap: {[key: string]: number} = {
  'Nativo': 100, 'C2': 95, 'C1': 85, 'B2': 70, 'B1': 55, 'A2': 40, 'A1': 25
};

const languagesWithPct = languages.map((lang: any) => ({
  ...lang,
  pct: levelMap[lang.level] ?? 70
}));
---

<div class="cv-sidebar-container">
  {skills && skills.length > 0 && (
    <div class="cv-block glass reveal delay-1">
      <h3 class="cv-block-title">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
        Core Skills
      </h3>
      <div class="skills-grid">
        {skills.map((skill: string) => <span class="skill-pill">{skill}</span>)}
      </div>
    </div>
  )}

  {tools && tools.length > 0 && (
    <div class="cv-block glass reveal delay-2">
      <h3 class="cv-block-title">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>
        Herramientas
      </h3>
      <div class="tools-list">
        {tools.map((tool: string) => (
          <div class="tool-item">
            <span class="tool-dot"></span>
            <span>{tool}</span>
          </div>
        ))}
      </div>
    </div>
  )}

  {languages && languages.length > 0 && (
    <div class="cv-block glass reveal delay-3">
      <h3 class="cv-block-title">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
        Idiomas
      </h3>
      <div class="langs-list">
        {languagesWithPct.map((lang: any) => (
          <div class="lang-item">
            <div class="lang-header">
              <strong>{lang.name}</strong>
              <span class="lang-level">{lang.level}</span>
            </div>
            <div class="lang-bar-bg">
              <div class="lang-bar-fill" style={`width: ${lang.pct}%`}></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}
</div>

<style>
  .cv-sidebar-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: sticky;
    top: 100px;
    margin-top: 4rem;
  }

  .cv-block {
    padding: 2rem;
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .cv-block-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .cv-block-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
  }

  .cv-block-title svg {
    opacity: 0.7;
    flex-shrink: 0;
  }

  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-pill {
    background: rgba(6, 182, 212, 0.08);
    color: var(--accent-cyan);
    border: 1px solid rgba(6, 182, 212, 0.2);
    padding: 0.45rem 0.9rem;
    border-radius: 100px;
    font-size: 0.82rem;
    font-family: var(--font-mono);
    transition: all 0.2s;
    cursor: default;
  }

  .skill-pill:hover {
    background: rgba(6, 182, 212, 0.18);
    border-color: rgba(6, 182, 212, 0.5);
    box-shadow: 0 0 12px rgba(6, 182, 212, 0.2);
    transform: translateY(-1px);
  }

  .tools-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .tool-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
    transition: color 0.2s;
  }

  .tool-item:hover { color: #fff; }

  .tool-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent-pink);
    box-shadow: 0 0 6px var(--accent-pink);
    flex-shrink: 0;
  }

  .langs-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .lang-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .lang-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .lang-header strong { color: #fff; font-size: 0.95rem; }

  .lang-level {
    font-size: 0.78rem;
    font-family: var(--font-mono);
    color: var(--accent-cyan);
    background: rgba(6, 182, 212, 0.1);
    border: 1px solid rgba(6, 182, 212, 0.2);
    padding: 0.15rem 0.5rem;
    border-radius: 100px;
  }

  .lang-bar-bg {
    width: 100%;
    height: 4px;
    background: rgba(255,255,255,0.07);
    border-radius: 100px;
    overflow: hidden;
  }

  .lang-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent-cyan), var(--accent-purple));
    border-radius: 100px;
    box-shadow: 0 0 8px rgba(6, 182, 212, 0.4);
    transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @media (max-width: 900px) {
    .cv-sidebar-container {
      position: static;
      margin-top: 0;
    }
  }
</style>
