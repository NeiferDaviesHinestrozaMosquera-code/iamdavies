---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';

// Fetch published blog posts from Supabase (newest first)
const { data: sortedPosts = [] } = await supabase
  .from('blog_posts')
  .select('*')
  .eq('status', 'published')
  .order('created_at', { ascending: false });
const description = "Artículos técnicos, tutoriales y reflexiones sobre ingeniería de software, desarrollo frontend, UI/UX y el futuro de la web.";
const siteUrl = Astro.site || Astro.url.origin;

const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Blog Técnico de Dev Davies",
  "description": description,
  "url": new URL('blog', siteUrl).href,
  "blogPost": (sortedPosts || []).map(p => ({
    "@type": "BlogPosting",
    "headline": p.title,
    "description": p.description,
    "datePublished": p.created_at,
    "url": new URL(`blog/${p.slug}`, siteUrl).href
  }))
};
---

<Layout title="iamdavies | Blog Técnico" description={description} schema={schema}>
  <div class="starfield"></div>
  <div class="nebula-glow nebula-cyan"></div>

  <section class="blog-section container">
    <div class="header-content reveal">
      <h1 class="page-title"><span class="gradient-text">/</span> Insights</h1>
      <p class="subtitle">Artículos sobre ingeniería frontend, UI/UX y el futuro de la web.</p>
    </div>

    <div class="blog-grid">
      {sortedPosts.map((post, index) => (
        <a href={`/blog/${post.slug}`} class={`blog-card glass reveal-scale delay-${(index % 3) + 1}`}>
          <div class="blog-card-content">
            <span class="blog-date">
              {new Date(post.created_at).toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: 'numeric' })}
            </span>
            <h2 class="blog-title">{post.title}</h2>
            <p class="blog-desc">{post.description}</p>
            
            <div class="blog-tags">
              {(post.tags || []).map((tag: string) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            
            <div class="read-more">
              <span>Leer artículo</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </div>
          </div>
        </a>
      ))}
      
      {sortedPosts.length === 0 && (
        <div class="empty-state glass">
          <p>Próximamente nuevos artículos...</p>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .blog-section {
    padding-top: 2rem;
    padding-bottom: 8rem;
    position: relative;
  }

  .header-content {
    margin-bottom: 4rem;
  }

  .page-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-family: var(--font-sans);
    font-weight: 800;
    margin-bottom: 1rem;
    color: #fff;
  }

  .subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 600px;
    line-height: 1.6;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 2rem;
  }

  .blog-card {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 2rem;
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all var(--transition-normal);
    position: relative;
    overflow: hidden;
  }

  .blog-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(90deg, var(--accent-cyan), var(--accent-purple));
    opacity: 0;
    transition: opacity var(--transition-normal);
  }

  .blog-card:hover {
    transform: translateY(-8px);
    border-color: rgba(6, 182, 212, 0.2);
    box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.5);
  }

  .blog-card:hover::before {
    opacity: 1;
  }

  .blog-date {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent-cyan);
    margin-bottom: 1rem;
    display: block;
  }

  .blog-title {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 1rem;
    line-height: 1.4;
    transition: color var(--transition-fast);
  }

  .blog-card:hover .blog-title {
    color: var(--accent-cyan);
  }

  .blog-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.25rem 0.75rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 100px;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .read-more {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
    transition: color var(--transition-fast);
  }

  .read-more svg {
    width: 16px;
    height: 16px;
    transition: transform var(--transition-fast);
  }

  .blog-card:hover .read-more {
    color: var(--accent-cyan);
  }

  .blog-card:hover .read-more svg {
    transform: translateX(4px);
  }

  .empty-state {
    padding: 4rem;
    text-align: center;
    color: var(--text-muted);
    border-radius: 24px;
    border: 1px dashed rgba(255, 255, 255, 0.1);
  }
</style>
