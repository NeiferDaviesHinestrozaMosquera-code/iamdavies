---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { createServerSupabaseClient } from '../../lib/supabase';

// Get cookies for authorized request
const accessToken = Astro.cookies.get('sb-access-token')?.value;
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;

const supabase = await createServerSupabaseClient(accessToken, refreshToken);

// Fetch messages on the server
const { data: initialMessages = [], error } = await supabase
  .from('messages')
  .select('*')
  .order('created_at', { ascending: false });

if (error) {
  console.error("Error fetching messages on server:", error);
}

const unreadCount = initialMessages.filter((m: any) => !m.is_read).length;
---

<AdminLayout title="Bandeja de Mensajes">
  <div class="page-header">
    <div>
      <h1 class="page-title">Mensajes</h1>
      <p class="page-subtitle">Revisa las solicitudes de contacto de tus clientes.</p>
    </div>
    <div class="header-actions">
      <button class="mark-all-btn" id="mark-all-read-btn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        Marcar todo como leído
      </button>
    </div>
  </div>

  <!-- Hidden data element for initial messages SSR -->
  <div id="initial-messages-data" data-messages={JSON.stringify(initialMessages)} style="display:none;"></div>

  <!-- Loading (hidden by default) -->
  <div id="inbox-loading" class="loading-full" style="display:none;">
    <div class="loading-spinner"></div>
    <span>Cargando mensajes...</span>
  </div>

  <!-- Empty state -->
  <div id="inbox-empty" class="empty-full glass" style={initialMessages.length === 0 ? "display:flex;" : "display:none;"}>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
      <polyline points="22,6 12,13 2,6"></polyline>
    </svg>
    <h3>Bandeja vacía</h3>
    <p>Cuando alguien envíe un mensaje desde tu formulario de contacto, aparecerá aquí.</p>
  </div>

  <!-- Inbox Layout -->
  <div class="inbox-layout" id="inbox-layout" style={initialMessages.length > 0 ? "display:grid;" : "display:none;"}>
    <!-- Sidebar Message List -->
    <div class="message-list glass" id="message-list-pane">
      <div class="list-header">
        <h3>Bandeja de Entrada</h3>
        <span class="unread-count" id="unread-count-label">{unreadCount} nuevo{unreadCount !== 1 ? 's' : ''}</span>
      </div>
      <div id="message-list-items">
        {initialMessages.map(m => {
          const initials = m.name.split(' ').map((w: string) => w[0]).join('').slice(0, 2).toUpperCase();
          const date = new Date(m.created_at).toLocaleDateString('es-ES', { day: '2-digit', month: 'short' });
          const snippet = m.message.length > 60 ? m.message.slice(0, 60) + '…' : m.message;
          return (
            <div class={`msg-item ${!m.is_read ? 'unread' : ''}`} data-id={m.id}>
              <div class="msg-avatar">{initials}</div>
              <div class="msg-content-preview">
                <div class="msg-meta">
                  <span class="msg-sender">{m.name}</span>
                  <span class="msg-time">{date}</span>
                </div>
                <span class="msg-subject">{m.subject}</span>
                <p class="msg-snippet">{snippet}</p>
              </div>
              {!m.is_read && <div class="unread-dot"></div>}
            </div>
          );
        })}
      </div>
    </div>

    <!-- Message Viewer Pane -->
    <div class="message-viewer glass" id="message-viewer">
      <!-- No selection -->
      <div class="no-selection" id="no-selection">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
          <polyline points="22,6 12,13 2,6"></polyline>
        </svg>
        <p>Selecciona un mensaje para leerlo</p>
      </div>

      <!-- Viewer content -->
      <div id="viewer-content" style="display:none; flex-direction:column; height:100%;">
        <!-- Back button (Volver a la lista) -->
        <div class="mobile-back-bar" id="mobile-back-bar">
          <button class="back-to-list-btn" id="back-to-list-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
            Volver a la lista
          </button>
        </div>
        <div class="viewer-header">
          <div class="viewer-sender-info">
            <div class="msg-avatar lg" id="viewer-avatar">?</div>
            <div>
              <h2 class="viewer-name" id="viewer-name">—</h2>
              <span class="viewer-email" id="viewer-email">—</span>
            </div>
          </div>
          <div class="viewer-actions">
            <button class="icon-btn" id="toggle-read-btn" title="Marcar como no leído">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </button>
            <button class="icon-btn delete" id="delete-msg-btn" title="Eliminar mensaje">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="3 6 5 6 21 6"></polyline>
                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
              </svg>
            </button>
          </div>
        </div>

        <div class="viewer-body">
          <h1 class="viewer-subject" id="viewer-subject">—</h1>
          <span class="viewer-date" id="viewer-date">—</span>
          <div class="viewer-text" id="viewer-text"></div>
        </div>

        <div class="viewer-reply">
          <textarea id="reply-textarea" placeholder="Escribe tu respuesta aquí... (abre tu cliente de correo)"></textarea>
          <button class="reply-btn glow-effect" id="reply-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="22" y1="2" x2="11" y2="13"></line>
              <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
            </svg>
            Responder por Email
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Delete Confirm Modal -->
  <div class="modal-backdrop" id="delete-backdrop" style="display:none;">
    <div class="modal-sm glass">
      <div class="modal-header">
        <h3>¿Eliminar mensaje?</h3>
        <button class="modal-close" id="delete-close">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <p style="color: var(--text-secondary); margin: 0.5rem 0 1.5rem;">Esta acción no se puede deshacer.</p>
      <div class="modal-actions">
        <button class="cancel-btn" id="delete-cancel">Cancelar</button>
        <button class="delete-confirm-btn" id="delete-confirm">
          <span id="del-txt">Eliminar</span>
          <div id="del-spin" style="display:none;"><div class="spinner"></div></div>
        </button>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div class="toast" id="toast" style="display:none;"></div>
</AdminLayout>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2rem;
  }

  .page-title {
    font-size: 2.2rem;
    font-weight: 800;
    margin: 0 0 0.5rem 0;
    color: #fff;
  }

  .page-subtitle { color: var(--text-secondary); margin: 0; font-size: 1.05rem; }

  .mark-all-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: var(--text-secondary);
    padding: 0.65rem 1.25rem;
    border-radius: 10px;
    font-weight: 500;
    cursor: pointer;
    font-size: 0.9rem;
    transition: all 0.2s;
  }

  .mark-all-btn:hover { background: rgba(255,255,255,0.1); color: #fff; }
  .mark-all-btn svg { width: 16px; height: 16px; }

  /* Loading / Empty */
  .loading-full {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    height: 300px;
    color: var(--text-muted);
  }

  .loading-spinner {
    width: 22px;
    height: 22px;
    border: 2px solid rgba(255,255,255,0.1);
    border-top-color: var(--accent-cyan);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .empty-full {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding: 5rem 2rem;
    border-radius: 20px;
    text-align: center;
  }

  .empty-full svg { width: 64px; height: 64px; color: var(--text-muted); opacity: 0.3; }
  .empty-full h3 { color: #fff; margin: 0; font-size: 1.3rem; }
  .empty-full p { color: var(--text-muted); margin: 0; max-width: 400px; line-height: 1.6; }

  /* Inbox Layout */
  .inbox-layout {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: 1.5rem;
    height: calc(100vh - 200px);
  }

  /* List Pane */
  .message-list {
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .list-header {
    padding: 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    flex-shrink: 0;
  }

  .list-header h3 { margin: 0; font-size: 1.1rem; color: #fff; }

  .unread-count {
    font-size: 0.75rem;
    background: rgba(6, 182, 212, 0.2);
    color: var(--accent-cyan);
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
    font-weight: 600;
  }

  #message-list-items { overflow-y: auto; flex: 1; }

  .msg-item {
    display: flex;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    cursor: pointer;
    transition: all var(--transition-fast);
    position: relative;
  }

  .msg-item:hover { background: rgba(255, 255, 255, 0.02); }
  .msg-item.active { background: rgba(6, 182, 212, 0.05); border-left: 3px solid var(--accent-cyan); }

  .msg-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #0ea5e9, #6366f1);
    color: #fff;
    display: flex;
    justify-content: center;
    align-items: center;
    font-weight: 700;
    font-size: 0.9rem;
    flex-shrink: 0;
    text-transform: uppercase;
  }

  .msg-avatar.lg { width: 48px; height: 48px; font-size: 1.1rem; }

  .msg-content-preview { flex: 1; min-width: 0; }

  .msg-meta { display: flex; justify-content: space-between; margin-bottom: 0.25rem; }

  .msg-sender { color: #fff; font-weight: 600; font-size: 0.95rem; }
  .msg-time { color: var(--text-muted); font-size: 0.8rem; }

  .msg-subject {
    display: block;
    color: var(--text-secondary);
    font-weight: 500;
    font-size: 0.9rem;
    margin-bottom: 0.25rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .msg-item.unread .msg-sender, .msg-item.unread .msg-subject { color: #fff; font-weight: 700; }

  .msg-snippet {
    margin: 0;
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .unread-dot {
    width: 8px;
    height: 8px;
    background: var(--accent-cyan);
    border-radius: 50%;
    position: absolute;
    right: 1.5rem;
    top: 50%;
    transform: translateY(-50%);
    box-shadow: 0 0 8px var(--accent-cyan);
  }

  /* Viewer Pane */
  .message-viewer {
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .no-selection {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    height: 100%;
    color: var(--text-muted);
  }

  .no-selection svg { width: 48px; height: 48px; opacity: 0.3; }
  .no-selection p { margin: 0; font-size: 0.95rem; }

  .viewer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    flex-shrink: 0;
  }

  .viewer-sender-info { display: flex; align-items: center; gap: 1rem; }
  .viewer-name { font-size: 1.2rem; font-weight: 700; color: #fff; margin: 0 0 0.1rem 0; }
  .viewer-email { font-size: 0.85rem; color: var(--text-muted); }
  .viewer-actions { display: flex; gap: 0.5rem; }

  .icon-btn {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--text-secondary);
    border-radius: 8px;
    padding: 0.6rem;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
  }

  .icon-btn svg { width: 18px; height: 18px; }
  .icon-btn:hover { background: rgba(255, 255, 255, 0.1); color: #fff; }
  .icon-btn.delete:hover { background: rgba(236, 72, 153, 0.1); color: var(--accent-pink); border-color: var(--accent-pink); }

  .viewer-body { padding: 2rem; flex: 1; overflow-y: auto; }
  .viewer-subject { font-size: 1.5rem; color: #fff; margin: 0 0 0.5rem 0; }
  .viewer-date { display: block; font-size: 0.85rem; color: var(--text-muted); margin-bottom: 2rem; }
  .viewer-text { font-size: 1rem; line-height: 1.8; color: var(--text-secondary); }
  .viewer-text p { margin-bottom: 1.25rem; }

  .viewer-reply {
    padding: 1.5rem 2rem;
    background: rgba(0, 0, 0, 0.15);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex-shrink: 0;
  }

  .viewer-reply textarea {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 1rem;
    color: #fff;
    font-family: inherit;
    font-size: 0.95rem;
    min-height: 80px;
    resize: none;
    outline: none;
  }

  .viewer-reply textarea:focus { border-color: var(--accent-cyan); box-shadow: 0 0 10px rgba(6, 182, 212, 0.1); }

  .reply-btn {
    align-self: flex-end;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--accent-cyan);
    color: var(--bg-primary);
    border: none;
    border-radius: 8px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
    font-size: 0.9rem;
  }

  .reply-btn svg { width: 16px; height: 16px; }
  .reply-btn:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(6, 182, 212, 0.4); }

  /* Delete Modal */
  .modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(8px);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .modal-sm {
    width: 100%;
    max-width: 420px;
    border-radius: 20px;
    padding: 2rem;
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .modal-header h3 { margin: 0; color: #fff; }

  .modal-close {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: var(--text-muted);
    border-radius: 8px;
    padding: 0.4rem;
    cursor: pointer;
    display: flex;
    transition: all 0.2s;
  }

  .modal-close:hover { color: #fff; }
  .modal-close svg { width: 16px; height: 16px; }

  .modal-actions { display: flex; justify-content: flex-end; gap: 1rem; }

  .cancel-btn {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: var(--text-secondary);
    padding: 0.7rem 1.25rem;
    border-radius: 10px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.2s;
  }

  .cancel-btn:hover { background: rgba(255,255,255,0.1); color: #fff; }

  .delete-confirm-btn {
    background: var(--accent-pink);
    border: none;
    color: #fff;
    padding: 0.7rem 1.5rem;
    border-radius: 10px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .delete-confirm-btn:hover { box-shadow: 0 5px 15px rgba(236, 72, 153, 0.4); }

  .spinner {
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }

  /* Toast */
  .toast {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    background: rgba(16, 185, 129, 0.9);
    backdrop-filter: blur(12px);
    color: #fff;
    padding: 1rem 1.5rem;
    border-radius: 12px;
    font-weight: 600;
    z-index: 9999;
    box-shadow: 0 8px 30px rgba(0,0,0,0.3);
  }

  .toast.error { background: rgba(236, 72, 153, 0.9); }

  .mobile-back-bar {
    display: block;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .back-to-list-btn {
    background: none;
    border: none;
    color: var(--accent-cyan);
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0;
    font-size: 0.95rem;
    transition: transform 0.2s, color 0.2s;
  }

  .back-to-list-btn:hover {
    color: #fff;
    transform: translateX(-2px);
  }

  /* Responsive Inbox master-detail navigation */
  @media (max-width: 850px) {
    .inbox-layout {
      grid-template-columns: 1fr;
      height: calc(100vh - 160px);
      position: relative;
    }
    
    .inbox-layout.viewing-message #message-list-pane {
      display: none !important;
    }
    
    .inbox-layout.viewing-message #message-viewer {
      display: flex !important;
      width: 100%;
    }
    
    .inbox-layout:not(.viewing-message) #message-list-pane {
      display: flex !important;
      width: 100%;
    }
    
    .inbox-layout:not(.viewing-message) #message-viewer {
      display: none !important;
    }
  }
</style>

<script>
  import { supabase } from '../../lib/supabase';
  import type { Message } from '../../lib/supabase';

  document.addEventListener('astro:page-load', () => {
    // Check if we are on the messages admin page
    const inboxLoading = document.getElementById('inbox-loading');
    if (!inboxLoading) return;

    let messages: Message[] = [];
    let activeId: string | null = null;
    let deletingId: string | null = null;

    const inboxEmpty   = document.getElementById('inbox-empty')!;
    const inboxLayout  = document.getElementById('inbox-layout')!;
    const msgListEl    = document.getElementById('message-list-items')!;
    const unreadLabel  = document.getElementById('unread-count-label')!;
    const noSelection  = document.getElementById('no-selection')!;
    const viewerContent = document.getElementById('viewer-content')!;
    const toast        = document.getElementById('toast')!;
    const deleteBackdrop = document.getElementById('delete-backdrop')!;
    const backToListBtn  = document.getElementById('back-to-list-btn')!;

    function showToast(msg: string, type: 'success' | 'error' = 'success') {
      toast.textContent = msg;
      toast.className = `toast${type === 'error' ? ' error' : ''}`;
      toast.style.display = 'block';
      setTimeout(() => { toast.style.display = 'none'; }, 3000);
    }

    // ── Load Messages ─────────────────────────────────────────────
    async function loadMessages(forceRefresh = false) {
      const dataEl = document.getElementById('initial-messages-data');
      // Only use SSR data if it actually has messages (not empty due to auth timing)
      if (dataEl && dataEl.dataset.messages && messages.length === 0 && !forceRefresh) {
        const parsed = JSON.parse(dataEl.dataset.messages);
        if (parsed.length > 0) {
          messages = parsed;
          inboxLoading.style.display = 'none';
          // Show the inbox layout (SSR may have set display:none)
          inboxLayout.style.display = 'grid';
          inboxEmpty.style.display = 'none';
          renderList();
          updateUnreadLabel();
          return;
        }
        // SSR had empty data — fall through to client-side fetch
      }

      inboxLoading.style.display = 'flex';
      inboxLayout.style.display = 'none';
      inboxEmpty.style.display = 'none';

      const { data, error } = await supabase
        .from('messages')
        .select('*')
        .order('created_at', { ascending: false });

      inboxLoading.style.display = 'none';

      if (error) { showToast('Error al cargar mensajes.', 'error'); return; }

      messages = (data as Message[]) || [];

      if (messages.length === 0) {
        inboxEmpty.style.display = 'flex';
        return;
      }

      inboxLayout.style.display = 'grid';
      renderList();
      updateUnreadLabel();
    }

    // ── Attach List Click Listeners ─────────────────────────────────
    function attachListListeners() {
      msgListEl.querySelectorAll('.msg-item').forEach(el => {
        el.addEventListener('click', () => selectMessage((el as HTMLElement).dataset.id!));
      });
    }

    // ── Render List ──────────────────────────────────────────────
    function renderList() {
      msgListEl.innerHTML = messages.map(m => {
        const initials = m.name.split(' ').map((w: string) => w[0]).join('').slice(0, 2).toUpperCase();
        const timeAgo = getTimeAgo(m.created_at);
        const snippet = m.message.length > 60 ? m.message.slice(0, 60) + '…' : m.message;
        const isActive = m.id === activeId;
        return `
          <div class="msg-item ${!m.is_read ? 'unread' : ''} ${isActive ? 'active' : ''}"
               data-id="${m.id}">
            <div class="msg-avatar">${initials}</div>
            <div class="msg-content-preview">
              <div class="msg-meta">
                <span class="msg-sender">${m.name}</span>
                <span class="msg-time">${timeAgo}</span>
              </div>
              <span class="msg-subject">${m.subject}</span>
              <p class="msg-snippet">${snippet}</p>
            </div>
            ${!m.is_read ? '<div class="unread-dot"></div>' : ''}
          </div>`;
      }).join('');

      attachListListeners();
    }

    // ── Update Unread Label ──
    function updateUnreadLabel() {
      const count = messages.filter(m => !m.is_read).length;
      unreadLabel.textContent = `${count} nuevo${count !== 1 ? 's' : ''}`;
    }

    // ── Select & View Message ─────────────────────────────────────
    async function selectMessage(id: string) {
      activeId = id;
      const m = messages.find(x => x.id === id);
      if (!m) return;

      // Slide/show message viewer on mobile
      inboxLayout.classList.add('viewing-message');

      // Mark as read in DB if unread
      if (!m.is_read) {
        await supabase.from('messages').update({ is_read: true }).eq('id', id);
        const idx = messages.findIndex(x => x.id === id);
        if (idx !== -1) messages[idx].is_read = true;
        updateUnreadLabel();
      }

      // Render viewer
      const initials = m.name.split(' ').map((w: string) => w[0]).join('').slice(0, 2).toUpperCase();
      document.getElementById('viewer-avatar')!.textContent = initials;
      document.getElementById('viewer-name')!.textContent   = m.name;
      document.getElementById('viewer-email')!.textContent  = m.email;
      document.getElementById('viewer-subject')!.textContent = m.subject;
      document.getElementById('viewer-date')!.textContent   = new Date(m.created_at).toLocaleString('es-ES', {
        weekday: 'long', day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit'
      });
      document.getElementById('viewer-text')!.innerHTML = m.message.split('\n').map(l => `<p>${l || '&nbsp;'}</p>`).join('');

      // Update toggle-read button
      const toggleBtn = document.getElementById('toggle-read-btn')!;
      toggleBtn.title = m.is_read ? 'Marcar como no leído' : 'Marcar como leído';

      noSelection.style.display = 'none';
      viewerContent.style.display = 'flex';

      renderList(); // Re-render to update active & read states
    }

    // ── Toggle Read ───────────────────────────────────────────────
    document.getElementById('toggle-read-btn')!.addEventListener('click', async () => {
      if (!activeId) return;
      const m = messages.find(x => x.id === activeId);
      if (!m) return;
      const newVal = !m.is_read;
      await supabase.from('messages').update({ is_read: newVal }).eq('id', activeId);
      m.is_read = newVal;
      showToast(newVal ? 'Marcado como leído.' : 'Marcado como no leído.');
      updateUnreadLabel();
      renderList();
      // Re-render viewer header button
      const toggleBtn = document.getElementById('toggle-read-btn')!;
      toggleBtn.title = newVal ? 'Marcar como no leído' : 'Marcar como leído';
    });

    // ── Delete Message ────────────────────────────────────────────
    document.getElementById('delete-msg-btn')!.addEventListener('click', () => {
      if (!activeId) return;
      deletingId = activeId;
      deleteBackdrop.style.display = 'flex';
    });

    document.getElementById('delete-confirm')!.addEventListener('click', async () => {
      if (!deletingId) return;
      const delBtn = document.getElementById('delete-confirm') as HTMLButtonElement;
      const delTxt = document.getElementById('del-txt')!;
      const delSpin = document.getElementById('del-spin')!;
      delBtn.disabled = true;
      delTxt.style.display = 'none';
      delSpin.style.display = 'flex';

      const { error } = await supabase.from('messages').delete().eq('id', deletingId);

      delBtn.disabled = false;
      delTxt.style.display = 'inline';
      delSpin.style.display = 'none';
      deleteBackdrop.style.display = 'none';

      if (error) { showToast('Error al eliminar.', 'error'); return; }

      messages = messages.filter(m => m.id !== deletingId);
      activeId = null;
      deletingId = null;

      noSelection.style.display = 'flex';
      viewerContent.style.display = 'none';
      inboxLayout.classList.remove('viewing-message');
      updateUnreadLabel();

      if (messages.length === 0) {
        inboxLayout.style.display = 'none';
        inboxEmpty.style.display = 'flex';
      } else {
        renderList();
      }
      showToast('Mensaje eliminado.');
    });

    // ── Mark All Read ─────────────────────────────────────────────
    document.getElementById('mark-all-read-btn')!.addEventListener('click', async () => {
      const unread = messages.filter(m => !m.is_read);
      if (unread.length === 0) return;
      await supabase.from('messages').update({ is_read: true }).eq('is_read', false);
      messages.forEach(m => m.is_read = true);
      updateUnreadLabel();
      renderList();
      showToast(`${unread.length} mensaje(s) marcados como leídos.`);
    });

    // ── Reply by Email ────────────────────────────────────────────
    document.getElementById('reply-btn')!.addEventListener('click', () => {
      if (!activeId) return;
      const m = messages.find(x => x.id === activeId);
      if (!m) return;
      const replyText = (document.getElementById('reply-textarea') as HTMLTextAreaElement).value;
      const subject = encodeURIComponent(`Re: ${m.subject}`);
      const body = encodeURIComponent(replyText || '');
      window.open(`mailto:${m.email}?subject=${subject}&body=${body}`);
    });

    // ── Back/exit message action ───────────────────────────────────
    backToListBtn?.addEventListener('click', () => {
      // Clear active message state
      activeId = null;
      
      // Hide viewer content and restore no-selection message
      viewerContent.style.display = 'none';
      noSelection.style.display = 'flex';
      
      // Remove active selection highlighting from list items
      msgListEl.querySelectorAll('.msg-item').forEach(el => {
        el.classList.remove('active');
      });
      
      // For mobile: transition screen state back to list
      inboxLayout.classList.remove('viewing-message');
    });

    // ── Modals ────────────────────────────────────────────────────
    document.getElementById('delete-close')!.addEventListener('click', () => { deleteBackdrop.style.display = 'none'; });
    document.getElementById('delete-cancel')!.addEventListener('click', () => { deleteBackdrop.style.display = 'none'; });

    // ── Helpers ───────────────────────────────────────────────────
    function getTimeAgo(dateStr: string): string {
      const diff = Date.now() - new Date(dateStr).getTime();
      const mins = Math.floor(diff / 60000);
      if (mins < 1) return 'Ahora';
      if (mins < 60) return `${mins}m`;
      const hours = Math.floor(mins / 60);
      if (hours < 24) return `${hours}h`;
      const days = Math.floor(hours / 24);
      if (days < 7) return `${days}d`;
      return new Date(dateStr).toLocaleDateString('es-ES', { day: '2-digit', month: 'short' });
    }

    // ── Init: restore session then load ───────────────────────────
    async function init() {
      // Restore session from cookies before any DB queries
      function getCookie(name: string): string | null {
        const match = document.cookie.match(new RegExp('(?:^|; )' + name + '=([^;]*)'));
        return match ? decodeURIComponent(match[1]) : null;
      }
      const accessToken = getCookie('sb-access-token');
      const refreshToken = getCookie('sb-refresh-token');
      if (accessToken && refreshToken) {
        const { data: { session } } = await supabase.auth.getSession();
        if (!session) {
          await supabase.auth.setSession({ access_token: accessToken, refresh_token: refreshToken });
        }
      }
      loadMessages();
    }

    init();
  });
</script>
