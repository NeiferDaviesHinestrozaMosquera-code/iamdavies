    // ── CV PDF UPLOAD LOGIC ──
    const cvImageArea = document.getElementById('cv-upload-area')!;
    const fCvFile = document.getElementById('f-cv-file') as HTMLInputElement;

    cvImageArea.addEventListener('click', () => fCvFile.click());

    fCvFile.addEventListener('change', async () => {
      const file = fCvFile.files?.[0];
      if (!file) return;

      if (file.type !== 'application/pdf') {
        showToast('Solo se permiten archivos PDF.', 'error');
        return;
      }

      // Clean up previous PDF from storage
      if (currentSettings && currentSettings.cv_pdf_url) {
        const oldPath = extractStoragePath(currentSettings.cv_pdf_url, 'documents');
        if (oldPath) {
          await supabase.storage.from('documents').remove([oldPath]);
        }
      }

      showToast('Subiendo archivo PDF...');
      const fileName = `cv-${Date.now()}.pdf`;
      
      // Upload to 'documents' bucket
      const { error: uploadError } = await supabase.storage
        .from('documents')
        .upload(fileName, file);

      if (uploadError) {
        showToast('Error al subir el PDF.', 'error');
        console.error(uploadError);
        return;
      }

      const { data: { publicUrl } } = supabase.storage
        .from('documents')
        .getPublicUrl(fileName);

      const { error: dbError } = await supabase
        .from('site_settings')
        .update({ cv_pdf_url: publicUrl })
        .eq('id', 1);

      if (dbError) {
        showToast('Error al actualizar base de datos.', 'error');
      } else {
        showToast('PDF actualizado correctamente.');
        if (currentSettings) {
          currentSettings.cv_pdf_url = publicUrl;
        }
        const dlLink = document.getElementById('cv-download-link') as HTMLAnchorElement;
        const placeholder = document.getElementById('cv-upload-placeholder')!;
        const preview = document.getElementById('cv-preview')!;
        const filenameLabel = document.getElementById('cv-filename')!;
        
        dlLink.href = publicUrl;
        filenameLabel.textContent = file.name;
        preview.style.display = 'flex';
        placeholder.style.display = 'none';
        document.getElementById('cv-file-info')!.style.display = 'block';
      }
    });

    document.getElementById('remove-cv-btn')!.addEventListener('click', async () => {
      // Clean up PDF from storage
      if (currentSettings && currentSettings.cv_pdf_url) {
        const oldPath = extractStoragePath(currentSettings.cv_pdf_url, 'documents');
        if (oldPath) {
          await supabase.storage.from('documents').remove([oldPath]);
        }
      }

      const { error } = await supabase.from('site_settings').update({ cv_pdf_url: null }).eq('id', 1);
      if (error) {
        showToast('Error al quitar PDF.', 'error');
      } else {
        showToast('PDF eliminado.');
        if (currentSettings) {
          currentSettings.cv_pdf_url = null;
        }
        document.getElementById('cv-preview')!.style.display = 'none';
        document.getElementById('cv-upload-placeholder')!.style.display = 'flex';
        document.getElementById('cv-file-info')!.style.display = 'none';
      }
    });

    // ── UPDATE PASSWORD ──
    document.getElementById('password-form')!.addEventListener('submit', async (e) => {
      e.preventDefault();
      const pwdError  = document.getElementById('pwd-error')!;
      const saveBtn   = document.getElementById('pwd-save-btn') as HTMLButtonElement;
      const btnText   = document.getElementById('pwd-btn-text')!;
      const spinner   = document.getElementById('pwd-spinner')!;
      const newPwd    = (document.getElementById('s-new-pwd') as HTMLInputElement).value;
      const confirmPwd = (document.getElementById('s-confirm-pwd') as HTMLInputElement).value;

      pwdError.style.display = 'none';

      if (!newPwd || newPwd.length < 6) {
        pwdError.textContent = 'La contraseña debe tener al menos 6 caracteres.';
        pwdError.style.display = 'block';
        return;
      }

      if (newPwd !== confirmPwd) {
        pwdError.textContent = 'Las contraseñas no coinciden.';
        pwdError.style.display = 'block';
        return;
      }

      saveBtn.disabled = true;
      btnText.style.display = 'none';
      spinner.style.display = 'flex';

      const { error } = await supabase.auth.updateUser({ password: newPwd });

      saveBtn.disabled = false;
      btnText.style.display = 'inline';
      spinner.style.display = 'none';

      if (error) {
        pwdError.textContent = error.message || 'Error al actualizar la contraseña.';
        pwdError.style.display = 'block';
      } else {
        showToast('Contraseña actualizada correctamente.');
        (document.getElementById('password-form') as HTMLFormElement).reset();
      }
    });

    // Initialization
    setupTabs();
    loadSettings();
  });
</script>
