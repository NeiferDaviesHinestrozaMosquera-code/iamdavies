---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { createServerSupabaseClient } from '../../lib/supabase';

// Get cookies for authorized request
const accessToken = Astro.cookies.get('sb-access-token')?.value;
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;

const supabase = await createServerSupabaseClient(accessToken, refreshToken);

// Fetch projects on the server
const { data: initialProjects = [], error } = await supabase
  .from('projects')
  .select('*')
  .order('created_at', { ascending: false });
---

<AdminLayout title="Gestión de Proyectos">
  <div class="page-header">
    <div>
      <h1 class="page-title">Proyectos</h1>
      <p class="page-subtitle">Gestiona tu portafolio de trabajos.</p>
    </div>
    <button class="action-btn glow-effect" id="open-create-btn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="12" y1="5" x2="12" y2="19"></line>
        <line x1="5" y1="12" x2="19" y2="12"></line>
      </svg>
      Crear Proyecto
    </button>
  </div>

  <!-- Filters Bar -->
  <div class="filters-bar glass">
    <div class="search-box">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <input type="text" id="search-input" placeholder="Buscar proyectos por nombre..." />
    </div>
    <div class="filter-options">
      <select class="custom-select" id="filter-category">
        <option value="">Todas las categorías</option>
        <option>FinTech</option>
        <option>E-commerce</option>
        <option>Dashboard</option>
        <option>Branding</option>
        <option>SaaS</option>
        <option>Mobile</option>
        <option>Otro</option>
      </select>
      <select class="custom-select" id="filter-status">
        <option value="">Todos los estados</option>
        <option value="published">Publicado</option>
        <option value="draft">Borrador</option>
        <option value="archived">Archivado</option>
      </select>
    </div>
  </div>

  <!-- Hidden data element for initial projects SSR -->
  <div id="initial-projects-data" data-projects={JSON.stringify(initialProjects)} style="display:none;"></div>

  <!-- Loading state -->
  <div id="table-loading" class="loading-state" style="display:none;">
    <div class="loading-spinner"></div>
    <span>Cargando proyectos...</span>
  </div>

  <!-- Empty state -->
  <div id="table-empty" class="empty-state glass" style={initialProjects.length === 0 ? "display:flex;" : "display:none;"}>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
    </svg>
    <p>No hay proyectos todavía.</p>
    <button class="action-btn" onclick="document.getElementById('open-create-btn').click()">Crear el primero</button>
  </div>

  <!-- Projects Table -->
  <div class="table-container glass" id="table-container" style={initialProjects.length > 0 ? "display:block;" : "display:none;"}>
    <table class="admin-table">
      <thead>
        <tr>
          <th>Proyecto</th>
          <th>Categoría</th>
          <th>Estado</th>
          <th>Fecha</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody id="projects-tbody">
        {initialProjects.map(p => {
          const initials = p.title.split(' ').map((w: string) => w[0]).join('').slice(0, 2).toUpperCase();
          const date = new Date(p.created_at).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' });
          const statusLabels: {[k:string]:string} = { published: 'Publicado', draft: 'Borrador', archived: 'Archivado' };
          const label = statusLabels[p.status] ?? p.status;
          return (
            <tr data-row-id={p.id}>
              <td>
                <div class="project-cell">
                  <div class="project-thumb">
                    {p.images_urls && p.images_urls.length > 0 ? <img src={p.images_urls[0]} alt={p.title} /> : initials}
                  </div>
                  <div class="project-info">
                    <span class="project-name">{p.title}</span>
                    {p.featured ? <span class="project-featured">★ Destacado</span> : null}
                  </div>
                </div>
              </td>
              <td>{p.category || '—'}</td>
              <td><span class={`status-badge status-${p.status}`}>{label}</span></td>
              <td>{date}</td>
              <td>
                <div class="actions-cell">
                  <button class="icon-btn edit-btn" title="Editar" data-id={p.id}>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                  </button>
                  <button class="icon-btn delete-btn" title="Eliminar" data-id={p.id} data-name={p.title}>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                  </button>
                </div>
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>

  <!-- ───────────────────────────── MODAL ───────────────────────────── -->
  <div class="modal-backdrop" id="modal-backdrop" style="display:none;">
    <div class="modal glass">
      <div class="modal-header">
        <h2 id="modal-title">Crear Proyecto</h2>
        <button class="modal-close" id="modal-close">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>

      <!-- Global error inside modal -->
      <div class="modal-error" id="modal-error" style="display:none;"></div>

      <form id="project-form" class="modal-form" novalidate>
        <input type="hidden" id="project-id" />

        <div class="form-row">
          <div class="input-group">
            <label for="f-title">Título *</label>
            <input type="text" id="f-title" placeholder="Ej: Nexus Banking App" required />
          </div>
          <div class="input-group">
            <label for="f-slug">Slug *</label>
            <input type="text" id="f-slug" placeholder="nexus-banking-app" required />
          </div>
        </div>

        <div class="form-row">
          <div class="input-group">
            <label for="f-category">Categoría</label>
            <input type="text" id="f-category" placeholder="FinTech, E-commerce, etc." />
          </div>
          <div class="input-group">
            <label for="f-status">Estado</label>
            <select id="f-status">
              <option value="draft">Borrador</option>
              <option value="published">Publicado</option>
              <option value="archived">Archivado</option>
            </select>
          </div>
        </div>

        <div class="input-group">
          <label for="f-description">Descripción</label>
          <textarea id="f-description" rows="3" placeholder="Descripción del proyecto..."></textarea>
        </div>

        <div class="input-group">
          <label for="f-tags">Tags (separados por coma)</label>
          <input type="text" id="f-tags" placeholder="React, TypeScript, Tailwind" />
        </div>

        <div class="form-row">
          <div class="input-group">
            <label for="f-live-url">URL Live</label>
            <input type="url" id="f-live-url" placeholder="https://..." />
          </div>
          <div class="input-group">
            <label for="f-github-url">URL GitHub</label>
            <input type="url" id="f-github-url" placeholder="https://github.com/..." />
          </div>
        </div>

        <!-- Image Upload -->
        <div class="input-group">
          <label>Imágenes del Proyecto</label>
          <div class="image-upload-area" id="image-upload-area" style="flex-direction: column;">
            <div class="upload-placeholder" id="upload-placeholder">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                <polyline points="21 15 16 10 5 21"></polyline>
              </svg>
              <span>Haz clic o arrastra imágenes</span>
              <small>PNG, JPG, WebP · Máx 5 MB c/u</small>
            </div>
            <div id="image-previews-container" class="image-previews-container" style="display:none;"></div>
            <input type="file" id="f-image" accept="image/*" multiple style="display:none;" />
          </div>
          <div id="current-image-info" style="display:none;">
            <small id="current-image-name" style="color: var(--text-muted);"></small>
            <button type="button" class="text-btn delete" id="remove-image-btn">Quitar todas</button>
          </div>
        </div>

        <div class="input-group checkbox-group">
          <label class="checkbox-label">
            <input type="checkbox" id="f-featured" />
            <span class="checkbox-custom"></span>
            Proyecto Destacado
          </label>
        </div>

        <div class="modal-actions">
          <button type="button" class="cancel-btn" id="cancel-btn">Cancelar</button>
          <button type="submit" class="save-btn glow-effect" id="form-save-btn">
            <span id="save-btn-text">Guardar Proyecto</span>
            <div class="btn-spinner" id="save-spinner" style="display:none;"><div class="spinner"></div></div>
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Delete Confirm Modal -->
  <div class="modal-backdrop" id="delete-backdrop" style="display:none;">
    <div class="modal modal-sm glass">
      <div class="modal-header">
        <h2>Eliminar Proyecto</h2>
        <button class="modal-close" id="delete-modal-close">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <div class="delete-body">
        <div class="delete-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="3 6 5 6 21 6"></polyline>
            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
          </svg>
        </div>
        <p>¿Seguro que deseas eliminar <strong id="delete-project-name"></strong>? Esta acción no se puede deshacer.</p>
      </div>
      <div class="modal-actions">
        <button class="cancel-btn" id="delete-cancel">Cancelar</button>
        <button class="delete-confirm-btn" id="delete-confirm">
          <span id="delete-btn-text">Eliminar</span>
          <div class="btn-spinner" id="delete-spinner" style="display:none;"><div class="spinner"></div></div>
        </button>
      </div>
    </div>
  </div>

  <!-- Toast Notification -->
  <div class="toast" id="toast" style="display:none;"></div>

</AdminLayout>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  @media (max-width: 768px) {
    .filters-bar {
      flex-direction: column;
      align-items: stretch;
    }
    .filter-options {
      flex-wrap: wrap;
    }
    .search-box {
      max-width: 100%;
    }
  }

  .page-title {
    font-size: 2.2rem;
    font-weight: 800;
    margin: 0 0 0.5rem 0;
    color: #fff;
  }

  .page-subtitle {
    color: var(--text-secondary);
    margin: 0;
    font-size: 1.05rem;
  }

  .action-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.5rem;
    background: var(--accent-cyan);
    border: none;
    color: var(--bg-primary);
    border-radius: 12px;
    font-weight: 700;
    cursor: pointer;
    transition: all var(--transition-normal);
    font-size: 0.95rem;
  }

  .action-btn svg { width: 18px; height: 18px; }

  .action-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(6, 182, 212, 0.4);
  }

  /* Filters */
  .filters-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    border-radius: 16px;
    margin-bottom: 2rem;
    gap: 1rem;
  }

  .search-box {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    max-width: 400px;
  }

  .search-box svg { width: 20px; height: 20px; color: var(--text-muted); flex-shrink: 0; }

  .search-box input {
    background: none;
    border: none;
    color: #fff;
    font-size: 0.95rem;
    width: 100%;
    outline: none;
  }

  .search-box input::placeholder { color: var(--text-muted); }

  .filter-options { display: flex; gap: 1rem; }

  .custom-select {
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--text-secondary);
    padding: 0.5rem 1rem;
    border-radius: 8px;
    outline: none;
    cursor: pointer;
  }

  /* Table */
  .table-container {
    padding: 1.5rem 2rem;
    border-radius: 20px;
    overflow-x: auto;
  }

  .admin-table { width: 100%; border-collapse: collapse; }

  .admin-table th {
    text-align: left;
    padding-bottom: 1rem;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .admin-table td {
    padding: 1.1rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    color: var(--text-secondary);
    font-size: 0.95rem;
    vertical-align: middle;
  }

  .project-cell { display: flex; align-items: center; gap: 1rem; }

  .project-thumb {
    width: 46px;
    height: 46px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--accent-cyan), var(--accent-purple));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
    overflow: hidden;
  }

  .project-thumb img { width: 100%; height: 100%; object-fit: cover; }

  .project-info { display: flex; flex-direction: column; gap: 0.2rem; }

  .project-name { color: #fff; font-weight: 600; font-size: 0.95rem; }

  .project-featured {
    font-size: 0.72rem;
    color: #f59e0b;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .status-badge {
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .status-published { background: rgba(16, 185, 129, 0.15); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.3); }
  .status-draft { background: rgba(245, 158, 11, 0.15); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.3); }
  .status-archived { background: rgba(161, 161, 170, 0.15); color: #a1a1aa; border: 1px solid rgba(161, 161, 170, 0.3); }

  .actions-cell { display: flex; gap: 0.5rem; }

  .icon-btn {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--text-secondary);
    border-radius: 8px;
    padding: 0.5rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }

  .icon-btn svg { width: 16px; height: 16px; }

  .edit-btn:hover { background: rgba(6, 182, 212, 0.1); color: var(--accent-cyan); border-color: var(--accent-cyan); }
  .delete-btn:hover { background: rgba(236, 72, 153, 0.1); color: var(--accent-pink); border-color: var(--accent-pink); }

  /* Loading / Empty */
  .loading-state {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 4rem 0;
    color: var(--text-muted);
  }

  .loading-spinner {
    width: 22px;
    height: 22px;
    border: 2px solid rgba(255,255,255,0.1);
    border-top-color: var(--accent-cyan);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding: 4rem 2rem;
    border-radius: 20px;
    color: var(--text-muted);
    text-align: center;
  }

  .empty-state svg { width: 56px; height: 56px; opacity: 0.3; }
  .empty-state p { margin: 0; font-size: 1rem; }

  /* Modal */
  .modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    animation: fade-in 0.2s ease;
  }

  @keyframes fade-in { from { opacity: 0; } to { opacity: 1; } }

  .modal {
    width: 100%;
    max-width: 850px;
    max-height: 90vh;
    overflow-y: auto;
    border-radius: 24px;
    padding: 2.5rem;
    animation: slide-up 0.25s ease;
    position: relative;
  }

  .modal-sm { max-width: 440px; }

  @keyframes slide-up {
    from { opacity: 0; transform: translateY(20px) scale(0.98); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .modal-header h2 { margin: 0; font-size: 1.4rem; color: #fff; }

  .modal-close {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: var(--text-muted);
    border-radius: 8px;
    padding: 0.5rem;
    cursor: pointer;
    display: flex;
    transition: all 0.2s;
  }

  .modal-close:hover { background: rgba(255,255,255,0.1); color: #fff; }
  .modal-close svg { width: 18px; height: 18px; }

  .modal-error {
    background: rgba(236, 72, 153, 0.1);
    border: 1px solid rgba(236, 72, 153, 0.3);
    border-radius: 10px;
    padding: 0.85rem 1.25rem;
    color: var(--accent-pink);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .modal-form { display: flex; flex-direction: column; gap: 1.25rem; }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }

  .input-group { display: flex; flex-direction: column; gap: 0.5rem; }

  .input-group label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary);
  }

  .input-group input, .input-group textarea, .input-group select {
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.85rem 1rem;
    border-radius: 10px;
    color: #fff;
    font-family: inherit;
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .input-group textarea { resize: vertical; min-height: 80px; }

  .input-group input:focus, .input-group textarea:focus, .input-group select:focus {
    border-color: var(--accent-cyan);
    box-shadow: 0 0 12px rgba(6, 182, 212, 0.15);
  }

  /* Image Upload */
  .image-upload-area {
    border: 2px dashed rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    min-height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .image-upload-area:hover {
    border-color: var(--accent-cyan);
    background: rgba(6, 182, 212, 0.03);
  }

  .image-upload-area.drag-over {
    border-color: var(--accent-cyan);
    background: rgba(6, 182, 212, 0.08);
  }

  .upload-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-muted);
  }

  .upload-placeholder svg { width: 40px; height: 40px; opacity: 0.5; }
  .upload-placeholder span { font-size: 0.95rem; font-weight: 500; }
  .upload-placeholder small { font-size: 0.8rem; }

  .image-previews-container {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    width: 100%;
    margin-top: 1rem;
    justify-content: center;
  }

  .image-preview-item {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  #current-image-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.5rem;
  }

  /* Checkbox */
  .checkbox-group { flex-direction: row; align-items: center; }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .checkbox-label input { display: none; }

  .checkbox-custom {
    width: 20px;
    height: 20px;
    border: 2px solid rgba(255,255,255,0.2);
    border-radius: 5px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .checkbox-label input:checked + .checkbox-custom {
    background: var(--accent-cyan);
    border-color: var(--accent-cyan);
  }

  .checkbox-label input:checked + .checkbox-custom::after {
    content: '✓';
    color: #000;
    font-size: 0.8rem;
    font-weight: 700;
  }

  .modal-actions {
    display: flex;
    justify-content: flex-end;
    gap: 1rem;
    margin-top: 0.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  .cancel-btn {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: var(--text-secondary);
    padding: 0.75rem 1.5rem;
    border-radius: 10px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.2s;
  }

  .cancel-btn:hover { background: rgba(255,255,255,0.1); color: #fff; }

  .save-btn {
    background: var(--accent-cyan);
    border: none;
    color: var(--bg-primary);
    padding: 0.75rem 2rem;
    border-radius: 10px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 160px;
    justify-content: center;
  }

  .save-btn:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(6, 182, 212, 0.4); }
  .save-btn:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }

  /* Delete modal */
  .delete-body { padding: 1rem 0 2rem; text-align: center; }

  .delete-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: rgba(236, 72, 153, 0.1);
    border: 1px solid rgba(236, 72, 153, 0.3);
    color: var(--accent-pink);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
  }

  .delete-icon svg { width: 28px; height: 28px; }

  .delete-body p { color: var(--text-secondary); line-height: 1.6; margin: 0; }
  .delete-body strong { color: #fff; }

  .delete-confirm-btn {
    background: var(--accent-pink);
    border: none;
    color: #fff;
    padding: 0.75rem 2rem;
    border-radius: 10px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 120px;
    justify-content: center;
  }

  .delete-confirm-btn:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(236, 72, 153, 0.4); }

  .btn-spinner { display: flex; }

  .spinner {
    width: 18px;
    height: 18px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }

  /* Text btn */
  .text-btn { background: none; border: none; font-weight: 500; cursor: pointer; transition: color 0.2s; padding: 0; }
  .text-btn.delete { color: var(--accent-pink); font-size: 0.85rem; }
  .text-btn.delete:hover { color: #ff4d8d; }

  /* Toast */
  .toast {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    background: rgba(16, 185, 129, 0.9);
    backdrop-filter: blur(12px);
    color: #fff;
    padding: 1rem 1.5rem;
    border-radius: 12px;
    font-weight: 600;
    z-index: 9999;
    box-shadow: 0 8px 30px rgba(0,0,0,0.3);
    animation: toast-in 0.3s ease;
    max-width: 350px;
  }

  .toast.error { background: rgba(236, 72, 153, 0.9); }

  @keyframes toast-in {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Responsive styles for form columns and modals */
  @media (max-width: 650px) {
    .form-row {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .modal {
      padding: 1.5rem;
      border-radius: 16px;
    }
    .modal-actions {
      flex-direction: column-reverse;
      gap: 0.75rem;
    }
    .modal-actions button {
      width: 100%;
    }
  }
</style>

<script>
  import { supabase } from '../../lib/supabase';
  import type { Project } from '../../lib/supabase';

  document.addEventListener('astro:page-load', () => {
    // Check if we are on the projects admin page to avoid errors when loading other pages
    const tbody = document.getElementById('projects-tbody');
    if (!tbody) return;

    // ── State ──────────────────────────────────────────────────
    let allProjects: Project[] = [];
    let editingId: string | null = null;
    let deletingId: string | null = null;
    let imageFiles: File[] = [];
    let existingImageUrls: string[] = [];

    // ── Elements ────────────────────────────────────────────────
    const tableLoading   = document.getElementById('table-loading')!;
    const tableContainer = document.getElementById('table-container')!;
    const tableEmpty     = document.getElementById('table-empty')!;
    const modalBackdrop  = document.getElementById('modal-backdrop')!;
    const deleteBackdrop = document.getElementById('delete-backdrop')!;
    const modalTitle     = document.getElementById('modal-title')!;
    const modalError     = document.getElementById('modal-error')!;
    const projectForm    = document.getElementById('project-form') as HTMLFormElement;
    const fTitle         = document.getElementById('f-title') as HTMLInputElement;
    const fSlug          = document.getElementById('f-slug') as HTMLInputElement;
    const fCategory      = document.getElementById('f-category') as HTMLInputElement;
    const fStatus        = document.getElementById('f-status') as HTMLSelectElement;
    const fDescription   = document.getElementById('f-description') as HTMLTextAreaElement;
    const fTags          = document.getElementById('f-tags') as HTMLInputElement;
    const fLiveUrl       = document.getElementById('f-live-url') as HTMLInputElement;
    const fGithubUrl     = document.getElementById('f-github-url') as HTMLInputElement;
    const fFeatured      = document.getElementById('f-featured') as HTMLInputElement;
    const fImage         = document.getElementById('f-image') as HTMLInputElement;
    const imagePreviewsContainer = document.getElementById('image-previews-container') as HTMLDivElement;
    const uploadPlaceholder = document.getElementById('upload-placeholder')!;
    const currentImageInfo  = document.getElementById('current-image-info')!;
    const currentImageName  = document.getElementById('current-image-name')!;
    const imageUploadArea   = document.getElementById('image-upload-area')!;
    const saveBtnText    = document.getElementById('save-btn-text')!;
    const saveSpinner    = document.getElementById('save-spinner')!;
    const formSaveBtn    = document.getElementById('form-save-btn') as HTMLButtonElement;
    const searchInput    = document.getElementById('search-input') as HTMLInputElement;
    const filterCategory = document.getElementById('filter-category') as HTMLSelectElement;
    const filterStatus   = document.getElementById('filter-status') as HTMLSelectElement;
    const toast          = document.getElementById('toast')!;

    // ── Toast ────────────────────────────────────────────────────
    function showToast(msg: string, type: 'success' | 'error' = 'success') {
      toast.textContent = msg;
      toast.className = `toast ${type === 'error' ? 'error' : ''}`;
      toast.style.display = 'block';
      setTimeout(() => { toast.style.display = 'none'; }, 3500);
    }

    // ── Load Projects ────────────────────────────────────────────
    async function loadProjects(forceRefresh = false) {
      const dataEl = document.getElementById('initial-projects-data');
      if (dataEl && dataEl.dataset.projects && allProjects.length === 0 && !forceRefresh) {
        allProjects = JSON.parse(dataEl.dataset.projects);
        attachRowEventListeners();
        return;
      }

      tableLoading.style.display = 'flex';
      tableContainer.style.display = 'none';
      tableEmpty.style.display = 'none';

      const { data, error } = await supabase
        .from('projects')
        .select('*')
        .order('created_at', { ascending: false });

      tableLoading.style.display = 'none';

      if (error) { showToast('Error al cargar proyectos.', 'error'); return; }

      allProjects = data as Project[];
      renderTable(allProjects);
    }

    // ── Attach row event listeners ─────────────────────────────────
    function attachRowEventListeners() {
      tbody.querySelectorAll('.edit-btn').forEach(btn => {
        btn.addEventListener('click', () => openEditModal((btn as HTMLElement).dataset.id!));
      });
      tbody.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', () => openDeleteModal((btn as HTMLElement).dataset.id!, (btn as HTMLElement).dataset.name!));
      });
    }

    // ── Render Table ─────────────────────────────────────────────
    function renderTable(projects: Project[]) {
      if (!projects || projects.length === 0) {
        tableContainer.style.display = 'none';
        tableEmpty.style.display = 'flex';
        return;
      }
      tableEmpty.style.display = 'none';
      tableContainer.style.display = 'block';

      const statusLabels: {[k:string]:string} = { published: 'Publicado', draft: 'Borrador', archived: 'Archivado' };

      tbody.innerHTML = projects.map(p => {
        const initials = p.title.split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase();
        const date = new Date(p.created_at).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' });
        return `
          <tr>
            <td>
              <div class="project-cell">
                <div class="project-thumb">
                  ${p.images_urls && p.images_urls.length > 0 ? `<img src="${p.images_urls[0]}" alt="${p.title}" />` : initials}
                </div>
                <div class="project-info">
                  <span class="project-name">${p.title}</span>
                  ${p.featured ? '<span class="project-featured">★ Destacado</span>' : ''}
                </div>
              </div>
            </td>
            <td>${p.category || '—'}</td>
            <td><span class="status-badge status-${p.status}">${statusLabels[p.status] ?? p.status}</span></td>
            <td>${date}</td>
            <td>
              <div class="actions-cell">
                <button class="icon-btn edit-btn" title="Editar" data-id="${p.id}">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                </button>
                <button class="icon-btn delete-btn" title="Eliminar" data-id="${p.id}" data-name="${p.title}">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                </button>
              </div>
            </td>
          </tr>`;
      }).join('');

      attachRowEventListeners();
    }

    // ── Filters ───────────────────────────────────────────────────
    function applyFilters() {
      const q = searchInput.value.toLowerCase();
      const cat = filterCategory.value.toLowerCase();
      const st = filterStatus.value;
      renderTable(allProjects.filter(p =>
        (p.title.toLowerCase().includes(q) || p.category.toLowerCase().includes(q)) &&
        (!cat || p.category.toLowerCase().includes(cat)) &&
        (!st || p.status === st)
      ));
    }

    searchInput.addEventListener('input', applyFilters);
    filterCategory.addEventListener('change', applyFilters);
    filterStatus.addEventListener('change', applyFilters);

    // ── Open Modal: Create ────────────────────────────────────────
    document.getElementById('open-create-btn')!.addEventListener('click', () => {
      editingId = null;
      imageFiles = [];
      existingImageUrls = [];
      projectForm.reset();
      resetImageUI();
      modalError.style.display = 'none';
      modalTitle.textContent = 'Crear Proyecto';
      saveBtnText.textContent = 'Guardar Proyecto';
      openModal(modalBackdrop);
    });

    // ── Open Modal: Edit ──────────────────────────────────────────
    function openEditModal(id: string) {
      const p = allProjects.find(x => x.id === id);
      if (!p) return;
      editingId = id;
      imageFiles = [];
      existingImageUrls = p.images_urls || [];

      fTitle.value        = p.title;
      fSlug.value         = p.slug;
      fCategory.value     = p.category;
      fStatus.value       = p.status;
      fDescription.value  = p.description;
      fTags.value         = (p.tags || []).join(', ');
      fLiveUrl.value      = p.live_url || '';
      fGithubUrl.value    = p.github_url || '';
      fFeatured.checked   = p.featured;
      modalError.style.display = 'none';

      if (existingImageUrls.length > 0) {
        imagePreviewsContainer.innerHTML = existingImageUrls.map(url => `<img src="${url}" class="image-preview-item" />`).join('');
        imagePreviewsContainer.style.display = 'flex';
        uploadPlaceholder.style.display = 'none';
        currentImageName.textContent = `${existingImageUrls.length} imagen(es) guardada(s)`;
        currentImageInfo.style.display = 'flex';
      } else {
        resetImageUI();
      }

      modalTitle.textContent = 'Editar Proyecto';
      saveBtnText.textContent = 'Guardar Cambios';
      openModal(modalBackdrop);
    }

    // ── Auto-generate slug from title ────────────────────────────
    fTitle.addEventListener('input', () => {
      if (!editingId) {
        fSlug.value = fTitle.value
          .toLowerCase()
          .replace(/[^\w\s-]/g, '')
          .replace(/\s+/g, '-')
          .replace(/-+/g, '-')
          .trim();
      }
    });

    // ── Image Upload UI ───────────────────────────────────────────
    imageUploadArea.addEventListener('click', () => fImage.click());

    imageUploadArea.addEventListener('dragover', (e) => {
      e.preventDefault();
      imageUploadArea.classList.add('drag-over');
    });

    imageUploadArea.addEventListener('dragleave', () => imageUploadArea.classList.remove('drag-over'));

    imageUploadArea.addEventListener('drop', (e) => {
      e.preventDefault();
      imageUploadArea.classList.remove('drag-over');
      const files = Array.from(e.dataTransfer?.files || []);
      handleImageFiles(files);
    });

    fImage.addEventListener('change', () => {
      const files = Array.from(fImage.files || []);
      handleImageFiles(files);
    });

    async function compressImageToWebP(file: File): Promise<File> {
      return new Promise((resolve) => {
        const reader = new FileReader();
        reader.onload = (e) => {
          const img = new Image();
          img.onload = () => {
            const canvas = document.createElement('canvas');
            let width = img.width;
            let height = img.height;
            
            const MAX_WIDTH = 1920;
            const MAX_HEIGHT = 1080;
            if (width > height) {
              if (width > MAX_WIDTH) {
                height *= MAX_WIDTH / width;
                width = MAX_WIDTH;
              }
            } else {
              if (height > MAX_HEIGHT) {
                width *= MAX_HEIGHT / height;
                height = MAX_HEIGHT;
              }
            }
            
            canvas.width = width;
            canvas.height = height;
            const ctx = canvas.getContext('2d');
            if (!ctx) {
              resolve(file);
              return;
            }
            ctx.drawImage(img, 0, 0, width, height);
            
            canvas.toBlob((blob) => {
              if (!blob) {
                resolve(file);
                return;
              }
              const fileName = file.name.replace(/\.[^/.]+$/, "") + ".webp";
              const compressedFile = new File([blob], fileName, { type: 'image/webp' });
              resolve(compressedFile);
            }, 'image/webp', 0.8);
          };
          img.onerror = () => resolve(file);
          img.src = e.target?.result as string;
        };
        reader.onerror = () => resolve(file);
        reader.readAsDataURL(file);
      });
    }

    async function handleImageFiles(files: File[]) {
      const validFiles = files.filter(f => f.type.startsWith('image/') && f.size <= 5 * 1024 * 1024);
      if (files.length !== validFiles.length) {
        showToast('Algunas imágenes fueron omitidas (tamaño > 5MB o formato no válido).', 'error');
      }
      if (validFiles.length === 0) return;
      
      // Temporarily show processing state
      const originalContent = uploadPlaceholder.innerHTML;
      uploadPlaceholder.innerHTML = '<div class="spinner" style="border-color:rgba(255,255,255,0.3); border-top-color:var(--accent-cyan);"></div><span>Procesando...</span>';
      
      const processedFiles: File[] = [];
      for (const file of validFiles) {
        if (file.type === 'image/webp') {
          processedFiles.push(file);
        } else {
          const compressed = await compressImageToWebP(file);
          processedFiles.push(compressed);
        }
      }
      
      // Append new files
      imageFiles = [...imageFiles, ...processedFiles];
      
      // Restore UI
      uploadPlaceholder.innerHTML = originalContent;
      uploadPlaceholder.style.display = 'none';
      imagePreviewsContainer.style.display = 'flex';
      currentImageInfo.style.display = 'flex';
      
      // Render all current image files (URLs first, then files)
      renderPreviews();
    }
    
    function renderPreviews() {
      imagePreviewsContainer.innerHTML = existingImageUrls.map(url => `<img src="${url}" class="image-preview-item" />`).join('');
      
      imageFiles.forEach(file => {
        const reader = new FileReader();
        reader.onload = (e) => {
          const img = document.createElement('img');
          img.src = e.target?.result as string;
          img.className = 'image-preview-item';
          imagePreviewsContainer.appendChild(img);
        };
        reader.readAsDataURL(file);
      });
      
      const total = existingImageUrls.length + imageFiles.length;
      currentImageName.textContent = `${total} imagen(es) seleccionada(s)`;
    }

    document.getElementById('remove-image-btn')!.addEventListener('click', () => {
      imageFiles = [];
      existingImageUrls = [];
      resetImageUI();
    });

    function resetImageUI() {
      imagePreviewsContainer.innerHTML = '';
      imagePreviewsContainer.style.display = 'none';
      uploadPlaceholder.style.display = 'flex';
      currentImageInfo.style.display = 'none';
      fImage.value = '';
    }

    function extractStoragePath(publicUrl: string, bucket: string): string | null {
      const marker = `/object/public/${bucket}/`;
      const idx = publicUrl.indexOf(marker);
      if (idx === -1) return null;
      return publicUrl.substring(idx + marker.length);
    }

    // ── Form Submit (Create / Update) ─────────────────────────────
    projectForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!fTitle.value.trim() || !fSlug.value.trim()) {
        modalError.textContent = 'El título y el slug son requeridos.';
        modalError.style.display = 'block';
        return;
      }

      formSaveBtn.disabled = true;
      saveBtnText.style.display = 'none';
      saveSpinner.style.display = 'flex';
      modalError.style.display = 'none';

      try {
        // Clean up removed images from Supabase Storage
        if (editingId) {
          const originalProject = allProjects.find(x => x.id === editingId);
          if (originalProject && originalProject.images_urls) {
            const urlsToDelete = originalProject.images_urls.filter(url => !existingImageUrls.includes(url));
            if (urlsToDelete.length > 0) {
              const paths = urlsToDelete.map(url => extractStoragePath(url, 'project-images')).filter(Boolean) as string[];
              if (paths.length > 0) {
                await supabase.storage.from('project-images').remove(paths);
              }
            }
          }
        }

        // Upload new images if selected
        let finalUrls: string[] = [...existingImageUrls];
        if (imageFiles.length > 0) {
          for (let i = 0; i < imageFiles.length; i++) {
            const file = imageFiles[i];
            const ext = file.name.split('.').pop();
            const path = `${fSlug.value}-${Date.now()}-${i}.${ext}`;
            const { error: uploadErr } = await supabase.storage
              .from('project-images')
              .upload(path, file, { upsert: true });
            if (uploadErr) throw uploadErr;
            const { data: urlData } = supabase.storage.from('project-images').getPublicUrl(path);
            finalUrls.push(urlData.publicUrl);
          }
        }

        const payload = {
          title:       fTitle.value.trim(),
          slug:        fSlug.value.trim(),
          category:    fCategory.value.trim(),
          status:      fStatus.value as Project['status'],
          description: fDescription.value.trim(),
          tags:        fTags.value.split(',').map(t => t.trim()).filter(Boolean),
          live_url:    fLiveUrl.value.trim() || null,
          github_url:  fGithubUrl.value.trim() || null,
          featured:    fFeatured.checked,
          images_urls: finalUrls.length > 0 ? finalUrls : null,
        };

        let error;
        if (editingId) {
          ({ error } = await supabase.from('projects').update(payload).eq('id', editingId));
        } else {
          ({ error } = await supabase.from('projects').insert(payload));
        }

        if (error) throw error;

        closeModal(modalBackdrop);
        showToast(editingId ? 'Proyecto actualizado correctamente.' : 'Proyecto creado correctamente.');
        await loadProjects(true);
      } catch (err: any) {
        modalError.textContent = err?.message || 'Error al guardar el proyecto.';
        modalError.style.display = 'block';
      } finally {
        formSaveBtn.disabled = false;
        saveBtnText.style.display = 'inline';
        saveSpinner.style.display = 'none';
      }
    });

    // ── Delete Modal ──────────────────────────────────────────────
    function openDeleteModal(id: string, name: string) {
      deletingId = id;
      document.getElementById('delete-project-name')!.textContent = name;
      openModal(deleteBackdrop);
    }

    document.getElementById('delete-confirm')!.addEventListener('click', async () => {
      if (!deletingId) return;
      const deleteBtn = document.getElementById('delete-confirm') as HTMLButtonElement;
      const deleteBtnText = document.getElementById('delete-btn-text')!;
      const deleteSpinner = document.getElementById('delete-spinner')!;
      deleteBtn.disabled = true;
      deleteBtnText.style.display = 'none';
      deleteSpinner.style.display = 'flex';

      // Clean up all project images from Storage
      const project = allProjects.find(x => x.id === deletingId);
      if (project && project.images_urls && project.images_urls.length > 0) {
        const paths = project.images_urls.map(url => extractStoragePath(url, 'project-images')).filter(Boolean) as string[];
        if (paths.length > 0) {
          await supabase.storage.from('project-images').remove(paths);
        }
      }

      const { error } = await supabase.from('projects').delete().eq('id', deletingId);
      deleteBtn.disabled = false;
      deleteBtnText.style.display = 'inline';
      deleteSpinner.style.display = 'none';

      if (error) { showToast('Error al eliminar el proyecto.', 'error'); return; }

      closeModal(deleteBackdrop);
      showToast('Proyecto eliminado.');
      await loadProjects(true);
    });

    // ── Modal Helpers ─────────────────────────────────────────────
    function openModal(el: HTMLElement) { el.style.display = 'flex'; document.body.style.overflow = 'hidden'; }
    function closeModal(el: HTMLElement) { el.style.display = 'none'; document.body.style.overflow = ''; }

    document.getElementById('modal-close')!.addEventListener('click', () => closeModal(modalBackdrop));
    document.getElementById('cancel-btn')!.addEventListener('click', () => closeModal(modalBackdrop));
    document.getElementById('delete-modal-close')!.addEventListener('click', () => closeModal(deleteBackdrop));
    document.getElementById('delete-cancel')!.addEventListener('click', () => closeModal(deleteBackdrop));

    modalBackdrop.addEventListener('click', (e) => { if (e.target === modalBackdrop) closeModal(modalBackdrop); });
    deleteBackdrop.addEventListener('click', (e) => { if (e.target === deleteBackdrop) closeModal(deleteBackdrop); });

    // Init
    loadProjects();
  });
</script>
