---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { createServerSupabaseClient } from '../../lib/supabase';

// Get cookies for authorized request
const accessToken = Astro.cookies.get('sb-access-token')?.value;
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;

const supabase = await createServerSupabaseClient(accessToken, refreshToken);

// Fetch blog posts on the server
const { data: initialPosts = [], error } = await supabase
  .from('blog_posts')
  .select('*')
  .order('created_at', { ascending: false });
---

<AdminLayout title="Gestión de Blog | iamdavies">
  <div class="page-header">
    <div>
      <h1 class="page-title">Blog</h1>
      <p class="page-subtitle">Gestiona las publicaciones de tu blog.</p>
    </div>
    <button class="action-btn glow-effect" id="open-create-btn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="12" y1="5" x2="12" y2="19"></line>
        <line x1="5" y1="12" x2="19" y2="12"></line>
      </svg>
      Crear Artículo
    </button>
  </div>

  <!-- Filters Bar -->
  <div class="filters-bar glass">
    <div class="search-box">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <input type="text" id="search-input" placeholder="Buscar artículos por título o descripción..." />
    </div>
    <div class="filter-options">
      <select class="custom-select" id="filter-status">
        <option value="">Todos los estados</option>
        <option value="published">Publicado</option>
        <option value="draft">Borrador</option>
      </select>
    </div>
  </div>

  <!-- Hidden data element for initial posts SSR -->
  <div id="initial-posts-data" data-posts={JSON.stringify(initialPosts)} style="display:none;"></div>

  <!-- Loading state -->
  <div id="table-loading" class="loading-state" style="display:none;">
    <div class="loading-spinner"></div>
    <span>Cargando artículos...</span>
  </div>

  <!-- Empty state -->
  <div id="table-empty" class="empty-state glass" style={initialPosts.length === 0 ? "display:flex;" : "display:none;"}>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M12 20h9"></path>
      <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
    </svg>
    <p>No hay artículos todavía.</p>
    <button class="action-btn" onclick="document.getElementById('open-create-btn').click()">Crear el primero</button>
  </div>

  <!-- Posts Table -->
  <div class="table-container glass" id="table-container" style={initialPosts.length > 0 ? "display:block;" : "display:none;"}>
    <table class="admin-table">
      <thead>
        <tr>
          <th>Artículo</th>
          <th>Tags</th>
          <th>Estado</th>
          <th>Fecha</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody id="posts-tbody">
        {initialPosts.map(p => {
          const date = new Date(p.created_at).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' });
          const statusLabels: {[k:string]:string} = { published: 'Publicado', draft: 'Borrador' };
          const label = statusLabels[p.status] ?? p.status;
          return (
            <tr data-row-id={p.id}>
              <td>
                <div class="post-cell">
                  <div class="post-info">
                    <span class="post-name">{p.title}</span>
                    <span class="post-slug">/{p.slug}</span>
                  </div>
                </div>
              </td>
              <td>
                <div class="tags-list">
                  {p.tags && p.tags.map((t: string) => <span class="tag-badge">{t}</span>)}
                </div>
              </td>
              <td><span class={`status-badge status-${p.status}`}>{label}</span></td>
              <td>{date}</td>
              <td>
                <div class="actions-cell">
                  <button class="icon-btn edit-btn" title="Editar" data-id={p.id}>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                  </button>
                  <button class="icon-btn delete-btn" title="Eliminar" data-id={p.id} data-title={p.title}>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                  </button>
                </div>
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>

  <!-- ───────────────────────────── MODAL ───────────────────────────── -->
  <div class="modal-backdrop" id="modal-backdrop" style="display:none;">
    <div class="modal glass modal-lg">
      <div class="modal-header">
        <h2 id="modal-title">Crear Artículo</h2>
        <button class="modal-close" id="modal-close">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>

      <!-- Global error inside modal -->
      <div class="modal-error" id="modal-error" style="display:none;"></div>

      <form id="post-form" class="modal-form" novalidate>
        <input type="hidden" id="post-id" />

        <div class="form-row">
          <div class="input-group">
            <label for="f-title">Título *</label>
            <input type="text" id="f-title" placeholder="Ej: Introducción a Astro" required />
          </div>
          <div class="input-group">
            <label for="f-slug">Slug *</label>
            <input type="text" id="f-slug" placeholder="introduccion-a-astro" required />
          </div>
        </div>

        <div class="form-row">
          <div class="input-group">
            <label for="f-author">Autor</label>
            <input type="text" id="f-author" value="iamdavies" placeholder="iamdavies" />
          </div>
          <div class="input-group">
            <label for="f-status">Estado</label>
            <select id="f-status">
              <option value="draft">Borrador</option>
              <option value="published">Publicado</option>
            </select>
          </div>
        </div>

        <div class="input-group">
          <label for="f-description">Descripción corta *</label>
          <textarea id="f-description" rows="2" placeholder="Resumen rápido del artículo..." required></textarea>
        </div>

        <div class="input-group">
          <label for="f-tags">Tags (separados por coma)</label>
          <input type="text" id="f-tags" placeholder="Astro, Frontend, CSS" />
        </div>

        <!-- Markdown editor with Preview -->
        <div class="input-group">
          <div class="editor-header">
            <label for="f-content">Contenido (Markdown) *</label>
            <div class="editor-tabs">
              <button type="button" class="editor-tab active" id="btn-edit-mode">Editor</button>
              <button type="button" class="editor-tab" id="btn-preview-mode">Vista Previa</button>
            </div>
          </div>
          <div class="editor-container">
            <textarea id="f-content" rows="12" placeholder="Escribe el contenido de tu artículo usando Markdown..." required></textarea>
            <div id="editor-preview" class="editor-preview-pane markdown-body glass" style="display:none;"></div>
          </div>
        </div>

        <div class="modal-actions">
          <button type="button" class="cancel-btn" id="cancel-btn">Cancelar</button>
          <button type="submit" class="save-btn glow-effect" id="form-save-btn">
            <span id="save-btn-text">Guardar Artículo</span>
            <div class="btn-spinner" id="save-spinner" style="display:none;"><div class="spinner"></div></div>
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Delete Confirm Modal -->
  <div class="modal-backdrop" id="delete-backdrop" style="display:none;">
    <div class="modal modal-sm glass">
      <div class="modal-header">
        <h2>Eliminar Artículo</h2>
        <button class="modal-close" id="delete-modal-close">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <div class="delete-body">
        <div class="delete-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="3 6 5 6 21 6"></polyline>
            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
          </svg>
        </div>
        <p>¿Seguro que deseas eliminar <strong id="delete-post-title"></strong>? Esta acción no se puede deshacer.</p>
      </div>
      <div class="modal-actions">
        <button class="cancel-btn" id="delete-cancel">Cancelar</button>
        <button class="delete-confirm-btn" id="delete-confirm">
          <span id="delete-btn-text">Eliminar</span>
          <div class="btn-spinner" id="delete-spinner" style="display:none;"><div class="spinner"></div></div>
        </button>
      </div>
    </div>
  </div>

  <!-- Toast Notification -->
  <div class="toast" id="toast" style="display:none;"></div>
</AdminLayout>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .page-title {
    font-size: 2.2rem;
    font-weight: 800;
    margin: 0 0 0.5rem 0;
    color: #fff;
  }

  .page-subtitle {
    color: var(--text-secondary);
    margin: 0;
    font-size: 1.05rem;
  }

  .action-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.5rem;
    background: var(--accent-cyan);
    border: none;
    color: var(--bg-primary);
    border-radius: 12px;
    font-weight: 700;
    cursor: pointer;
    transition: all var(--transition-normal);
    font-size: 0.95rem;
  }

  .action-btn svg { width: 18px; height: 18px; }

  .action-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(6, 182, 212, 0.4);
  }

  /* Filters */
  .filters-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    border-radius: 16px;
    margin-bottom: 2rem;
    gap: 1rem;
  }

  .search-box {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    max-width: 400px;
  }

  .search-box svg { width: 20px; height: 20px; color: var(--text-muted); flex-shrink: 0; }

  .search-box input {
    background: none;
    border: none;
    color: #fff;
    font-size: 0.95rem;
    width: 100%;
    outline: none;
  }

  .search-box input::placeholder { color: var(--text-muted); }

  .filter-options { display: flex; gap: 1rem; }

  .custom-select {
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--text-secondary);
    padding: 0.5rem 1rem;
    border-radius: 8px;
    outline: none;
    cursor: pointer;
  }

  /* Table */
  .table-container {
    padding: 1.5rem 2rem;
    border-radius: 20px;
    overflow-x: auto;
  }

  .admin-table { width: 100%; border-collapse: collapse; }

  .admin-table th {
    text-align: left;
    padding-bottom: 1rem;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .admin-table td {
    padding: 1.1rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .post-cell {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .post-info {
    display: flex;
    flex-direction: column;
  }

  .post-name {
    font-weight: 600;
    color: #fff;
    font-size: 1.05rem;
  }

  .post-slug {
    font-size: 0.82rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag-badge {
    font-size: 0.72rem;
    padding: 0.15rem 0.45rem;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    color: var(--text-secondary);
  }

  .status-badge {
    display: inline-flex;
    padding: 0.25rem 0.6rem;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .status-published { background: rgba(16, 185, 129, 0.1); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.2); }
  .status-draft { background: rgba(245, 158, 11, 0.1); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.2); }

  .actions-cell {
    display: flex;
    gap: 0.5rem;
  }

  .icon-btn {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 8px;
    transition: all var(--transition-fast);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon-btn svg { width: 18px; height: 18px; }

  .icon-btn:hover { background: rgba(255, 255, 255, 0.05); color: #fff; }
  .icon-btn.delete-btn:hover { color: var(--accent-pink); background: rgba(236, 72, 153, 0.05); }

  /* Editor specific styling */
  .editor-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .editor-tabs {
    display: flex;
    gap: 0.25rem;
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.2rem;
    border-radius: 6px;
  }

  .editor-tab {
    background: none;
    border: none;
    color: var(--text-secondary);
    font-size: 0.8rem;
    padding: 0.3rem 0.8rem;
    border-radius: 4px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.2s;
  }

  .editor-tab.active {
    background: var(--accent-cyan);
    color: var(--bg-primary);
  }

  .editor-container {
    position: relative;
    width: 100%;
  }

  .editor-preview-pane {
    min-height: 270px;
    max-height: 400px;
    overflow-y: auto;
    padding: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    color: var(--text-secondary);
    background: rgba(0,0,0,0.15);
  }

  /* Modal styling extension */
  .modal-lg {
    max-width: 850px;
  }

  /* Textarea / markdown container */
  .markdown-body h1, .markdown-body h2, .markdown-body h3 {
    color: #fff;
    margin-top: 1.5rem;
    margin-bottom: 1rem;
    font-weight: 700;
  }
  .markdown-body h1 { font-size: 1.6rem; border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding-bottom: 0.3rem; }
  .markdown-body h2 { font-size: 1.3rem; }
  .markdown-body h3 { font-size: 1.1rem; }
  .markdown-body p { margin-bottom: 1rem; line-height: 1.6; }
  .markdown-body blockquote {
    border-left: 4px solid var(--accent-cyan);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--text-muted);
    font-style: italic;
  }
  .markdown-body code {
    background: rgba(255, 255, 255, 0.08);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent-pink);
  }
  .markdown-body pre {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  .markdown-body pre code {
    background: none;
    padding: 0;
    color: inherit;
    font-size: 0.85rem;
  }
  .markdown-body a {
    color: var(--accent-cyan);
    text-decoration: none;
  }
  .markdown-body a:hover {
    text-decoration: underline;
  }

  /* Modal styling */
  .modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(3, 0, 20, 0.8);
    backdrop-filter: blur(8px);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .modal {
    width: 100%;
    max-height: 90vh;
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    animation: modalReveal 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .modal-header h2 { font-size: 1.4rem; color: #fff; margin: 0; }

  .modal-close {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    border-radius: 50%;
    transition: all 0.2s;
  }

  .modal-close:hover { background: rgba(255, 255, 255, 0.05); color: #fff; }
  .modal-close svg { width: 20px; height: 20px; }

  .modal-error {
    background: rgba(236, 72, 153, 0.1);
    border-bottom: 1px solid rgba(236, 72, 153, 0.2);
    padding: 1rem 2rem;
    color: var(--accent-pink);
    font-size: 0.9rem;
  }

  .modal-form {
    padding: 2rem;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  @media (max-width: 600px) {
    .form-row { grid-template-columns: 1fr; gap: 1.25rem; }
    .modal-actions { flex-direction: column-reverse; gap: 0.75rem; }
    .modal-actions button { width: 100%; }
    .modal-backdrop { padding: 1rem; }
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .input-group label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary);
  }

  .input-group input, .input-group textarea, .input-group select {
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.85rem 1rem;
    border-radius: 10px;
    color: #fff;
    font-family: inherit;
    font-size: 0.95rem;
    outline: none;
    transition: all 0.2s;
  }

  .input-group select option {
    background: #030014;
    color: #fff;
  }

  .input-group textarea { resize: vertical; }

  .input-group input:focus, .input-group textarea:focus, .input-group select:focus {
    border-color: var(--accent-cyan);
    box-shadow: 0 0 12px rgba(6, 182, 212, 0.15);
  }

  .modal-actions {
    display: flex;
    justify-content: flex-end;
    gap: 1rem;
    margin-top: 1rem;
  }

  .cancel-btn {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #fff;
    padding: 0.85rem 1.5rem;
    border-radius: 10px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .cancel-btn:hover { background: rgba(255, 255, 255, 0.1); }

  .save-btn {
    background: var(--accent-cyan);
    color: var(--bg-primary);
    border: none;
    padding: 0.85rem 1.5rem;
    border-radius: 10px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .save-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(6, 182, 212, 0.4); }
  .save-btn:disabled { opacity: 0.7; cursor: not-allowed; }

  /* Delete Modal Specifics */
  .modal-sm { max-width: 450px; }
  .delete-body {
    padding: 2rem;
    text-align: center;
    color: var(--text-secondary);
  }
  .delete-icon {
    width: 60px;
    height: 60px;
    background: rgba(236, 72, 153, 0.1);
    border: 1px solid rgba(236, 72, 153, 0.2);
    color: var(--accent-pink);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem auto;
  }
  .delete-icon svg { width: 30px; height: 30px; }
  .delete-body p { margin: 0; font-size: 1rem; line-height: 1.5; }
  .delete-confirm-btn {
    background: var(--accent-pink);
    color: #fff;
    border: none;
    padding: 0.85rem 1.5rem;
    border-radius: 10px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .delete-confirm-btn:hover { box-shadow: 0 5px 15px rgba(236, 72, 153, 0.4); }

  /* Spinner */
  .btn-spinner { align-items: center; }
  .spinner {
    width: 18px;
    height: 18px;
    border: 2px solid rgba(0,0,0,0.3);
    border-top-color: var(--bg-primary);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }
  .delete-confirm-btn .spinner { border-top-color: #fff; }

  @keyframes spin { to { transform: rotate(360deg); } }

  /* Toast Notification */
  .toast {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    background: rgba(16, 185, 129, 0.9);
    backdrop-filter: blur(12px);
    color: #fff;
    padding: 1rem 1.5rem;
    border-radius: 12px;
    font-weight: 600;
    z-index: 9999;
    box-shadow: 0 8px 30px rgba(0,0,0,0.3);
    animation: toastSlideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .toast.error { background: rgba(236, 72, 153, 0.9); }

  @keyframes modalReveal {
    from { opacity: 0; transform: scale(0.95) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  @keyframes toastSlideIn {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  /* Loading State */
  .loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    height: 300px;
    color: var(--text-muted);
  }

  .loading-spinner {
    width: 40px;
    height: 40px;
    border: 3px solid rgba(255,255,255,0.05);
    border-top-color: var(--accent-cyan);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  /* Empty State */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    border-radius: 20px;
    color: var(--text-secondary);
    text-align: center;
    gap: 1rem;
  }

  .empty-state svg {
    width: 64px;
    height: 64px;
    color: var(--text-muted);
  }

  .empty-state p {
    margin: 0;
    font-size: 1.1rem;
  }
</style>

<script>
  import { supabase } from '../../lib/supabase';
  import type { BlogPost } from '../../lib/supabase';

  document.addEventListener('astro:page-load', () => {
    const tableLoading = document.getElementById('table-loading')!;
    const tableEmpty   = document.getElementById('table-empty')!;
    const tableContainer = document.getElementById('table-container')!;
    const tbody          = document.getElementById('posts-tbody')!;

    if (!tbody) return; // Not on the blog page

    const searchInput    = document.getElementById('search-input') as HTMLInputElement;
    const filterStatus   = document.getElementById('filter-status') as HTMLSelectElement;

    // Modal elements
    const modalBackdrop  = document.getElementById('modal-backdrop')!;
    const modalTitle     = document.getElementById('modal-title')!;
    const modalError     = document.getElementById('modal-error')!;
    const postForm       = document.getElementById('post-form') as HTMLFormElement;
    const formSaveBtn    = document.getElementById('form-save-btn') as HTMLButtonElement;
    const saveBtnText    = document.getElementById('save-btn-text')!;
    const saveSpinner    = document.getElementById('save-spinner')!;

    // Form inputs
    const fId            = document.getElementById('post-id') as HTMLInputElement;
    const fTitle         = document.getElementById('f-title') as HTMLInputElement;
    const fSlug          = document.getElementById('f-slug') as HTMLInputElement;
    const fAuthor        = document.getElementById('f-author') as HTMLInputElement;
    const fStatus        = document.getElementById('f-status') as HTMLSelectElement;
    const fDescription   = document.getElementById('f-description') as HTMLTextAreaElement;
    const fTags          = document.getElementById('f-tags') as HTMLInputElement;
    const fContent       = document.getElementById('f-content') as HTMLTextAreaElement;

    // Preview elements
    const btnEditMode    = document.getElementById('btn-edit-mode')!;
    const btnPreviewMode = document.getElementById('btn-preview-mode')!;
    const editorPreview  = document.getElementById('editor-preview')!;

    // Delete Modal elements
    const deleteBackdrop = document.getElementById('delete-backdrop')!;
    const deleteConfirm  = document.getElementById('delete-confirm')!;

    let allPosts: BlogPost[] = [];
    let editingId: string | null = null;
    let deletingId: string | null = null;

    // ── Toast System ──────────────────────────────────────────────
    function showToast(msg: string, type: 'success' | 'error' = 'success') {
      const toast = document.getElementById('toast')!;
      toast.textContent = msg;
      toast.className = `toast${type === 'error' ? ' error' : ''}`;
      toast.style.display = 'block';
      setTimeout(() => { toast.style.display = 'none'; }, 3000);
    }

    // ── Markdown Parser (Regex) ────────────────────────────────────
    function parseMarkdown(md: string): string {
      if (!md) return '';
      let html = md
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;");
      
      // Headers
      html = html.replace(/^### (.*$)/gim, '<h3>$1</h3>');
      html = html.replace(/^## (.*$)/gim, '<h2>$1</h2>');
      html = html.replace(/^# (.*$)/gim, '<h1>$1</h1>');
      
      // Code blocks (fenced)
      html = html.replace(/```([\s\S]*?)```/g, '<pre><code>$1</code></pre>');
      
      // Inline code
      html = html.replace(/`([^`]+)`/g, '<code>$1</code>');
      
      // Bold
      html = html.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
      
      // Italic
      html = html.replace(/\*([^*]+)\*/g, '<em>$1</em>');
      html = html.replace(/_([^_]+)_/g, '<em>$1</em>');
      
      // Blockquotes
      html = html.replace(/^\> (.*$)/gim, '<blockquote>$1</blockquote>');
      
      // Links
      html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>');
      
      // Paragraphs and line breaks
      const blocks = html.split(/\n\s*\n/);
      html = blocks.map(block => {
        block = block.trim();
        if (!block) return '';
        if (block.startsWith('<h') || block.startsWith('<pre') || block.startsWith('<blockquote')) {
          return block;
        }
        return `<p>${block.replace(/\n/g, '<br />')}</p>`;
      }).filter(Boolean).join('\n');

      return html;
    }

    // ── Load Blog Posts ───────────────────────────────────────────
    async function loadPosts(forceRefresh = false) {
      const dataEl = document.getElementById('initial-posts-data') as HTMLElement;
      if (dataEl && dataEl.dataset.posts && !forceRefresh) {
        allPosts = JSON.parse(dataEl.dataset.posts);
        attachRowEventListeners();
        return;
      }

      tableLoading.style.display = 'flex';
      tableContainer.style.display = 'none';
      tableEmpty.style.display = 'none';

      const { data, error } = await supabase
        .from('blog_posts')
        .select('*')
        .order('created_at', { ascending: false });

      tableLoading.style.display = 'none';

      if (error) { showToast('Error al cargar artículos.', 'error'); return; }

      allPosts = data as BlogPost[];
      renderTable(allPosts);
    }

    // ── Attach row event listeners ─────────────────────────────────
    function attachRowEventListeners() {
      tbody.querySelectorAll('.edit-btn').forEach(btn => {
        btn.addEventListener('click', () => openEditModal((btn as HTMLElement).dataset.id!));
      });
      tbody.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', () => openDeleteModal((btn as HTMLElement).dataset.id!, (btn as HTMLElement).dataset.title!));
      });
    }

    // ── Render Table ─────────────────────────────────────────────
    function renderTable(posts: BlogPost[]) {
      if (!posts || posts.length === 0) {
        tableContainer.style.display = 'none';
        tableEmpty.style.display = 'flex';
        return;
      }
      tableEmpty.style.display = 'none';
      tableContainer.style.display = 'block';

      const statusLabels: {[k:string]:string} = { published: 'Publicado', draft: 'Borrador' };

      tbody.innerHTML = posts.map(p => {
        const date = new Date(p.created_at).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' });
        const tagsHtml = (p.tags || []).map((t: string) => `<span class="tag-badge">${t}</span>`).join('');
        return `
          <tr>
            <td>
              <div class="post-cell">
                <div class="post-info">
                  <span class="post-name">${p.title}</span>
                  <span class="post-slug">/${p.slug}</span>
                </div>
              </div>
            </td>
            <td>
              <div class="tags-list">
                ${tagsHtml}
              </div>
            </td>
            <td><span class="status-badge status-${p.status}">${statusLabels[p.status] ?? p.status}</span></td>
            <td>{date}</td>
            <td>
              <div class="actions-cell">
                <button class="icon-btn edit-btn" title="Editar" data-id="${p.id}">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                </button>
                <button class="icon-btn delete-btn" title="Eliminar" data-id="${p.id}" data-title="${p.title}">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                </button>
              </div>
            </td>
          </tr>`;
      }).join('');

      attachRowEventListeners();
    }

    // ── Filters ───────────────────────────────────────────────────
    function applyFilters() {
      const q = searchInput.value.toLowerCase();
      const st = filterStatus.value;
      renderTable(allPosts.filter(p =>
        (p.title.toLowerCase().includes(q) || p.description.toLowerCase().includes(q)) &&
        (!st || p.status === st)
      ));
    }

    searchInput.addEventListener('input', applyFilters);
    filterStatus.addEventListener('change', applyFilters);

    // ── Open Modal: Create ────────────────────────────────────────
    document.getElementById('open-create-btn')!.addEventListener('click', () => {
      editingId = null;
      postForm.reset();
      fId.value = '';
      fAuthor.value = 'iamdavies';
      fStatus.value = 'draft';
      modalError.style.display = 'none';
      modalTitle.textContent = 'Crear Artículo';
      saveBtnText.textContent = 'Guardar Artículo';
      
      // Default to edit mode in editor
      showEditorTab('edit');
      
      openModal(modalBackdrop);
    });

    // ── Open Modal: Edit ──────────────────────────────────────────
    function openEditModal(id: string) {
      const p = allPosts.find(x => x.id === id);
      if (!p) return;
      editingId = id;

      fId.value          = p.id;
      fTitle.value       = p.title;
      fSlug.value        = p.slug;
      fAuthor.value      = p.author || 'iamdavies';
      fStatus.value      = p.status;
      fDescription.value = p.description || '';
      fTags.value        = (p.tags || []).join(', ');
      fContent.value     = p.content || '';
      
      modalError.style.display = 'none';
      modalTitle.textContent = 'Editar Artículo';
      saveBtnText.textContent = 'Guardar Cambios';
      
      showEditorTab('edit');
      
      openModal(modalBackdrop);
    }

    // ── Auto-generate slug from title ────────────────────────────
    fTitle.addEventListener('input', () => {
      if (!editingId) {
        fSlug.value = fTitle.value
          .toLowerCase()
          .replace(/[^\w\s-]/g, '')
          .replace(/\s+/g, '-')
          .replace(/-+/g, '-')
          .trim();
      }
    });

    // ── Editor / Preview Toggle tabs ─────────────────────────────
    function showEditorTab(mode: 'edit' | 'preview') {
      if (mode === 'edit') {
        btnEditMode.classList.add('active');
        btnPreviewMode.classList.remove('active');
        fContent.style.display = 'block';
        editorPreview.style.display = 'none';
      } else {
        btnEditMode.classList.remove('active');
        btnPreviewMode.classList.add('active');
        fContent.style.display = 'none';
        editorPreview.style.display = 'block';
        editorPreview.innerHTML = parseMarkdown(fContent.value);
      }
    }

    btnEditMode.addEventListener('click', () => showEditorTab('edit'));
    btnPreviewMode.addEventListener('click', () => showEditorTab('preview'));

    // ── Form Submit (Create / Update) ─────────────────────────────
    postForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!fTitle.value.trim() || !fSlug.value.trim() || !fContent.value.trim()) {
        modalError.textContent = 'El título, slug y contenido son requeridos.';
        modalError.style.display = 'block';
        return;
      }

      formSaveBtn.disabled = true;
      saveBtnText.style.display = 'none';
      saveSpinner.style.display = 'flex';
      modalError.style.display = 'none';

      try {
        const payload = {
          title:       fTitle.value.trim(),
          slug:        fSlug.value.trim(),
          author:      fAuthor.value.trim() || 'iamdavies',
          status:      fStatus.value as BlogPost['status'],
          description: fDescription.value.trim(),
          tags:        fTags.value.split(',').map(t => t.trim()).filter(Boolean),
          content:     fContent.value
        };

        let error;
        if (editingId) {
          ({ error } = await supabase.from('blog_posts').update(payload).eq('id', editingId));
        } else {
          ({ error } = await supabase.from('blog_posts').insert(payload));
        }

        if (error) throw error;

        closeModal(modalBackdrop);
        showToast(editingId ? 'Artículo actualizado correctamente.' : 'Artículo creado correctamente.');
        await loadPosts(true);
      } catch (err: any) {
        modalError.textContent = err?.message || 'Error al guardar el artículo.';
        modalError.style.display = 'block';
      } finally {
        formSaveBtn.disabled = false;
        saveBtnText.style.display = 'inline';
        saveSpinner.style.display = 'none';
      }
    });

    // ── Delete Modal ──────────────────────────────────────────────
    function openDeleteModal(id: string, title: string) {
      deletingId = id;
      document.getElementById('delete-post-title')!.textContent = title;
      openModal(deleteBackdrop);
    }

    document.getElementById('delete-confirm')!.addEventListener('click', async () => {
      if (!deletingId) return;
      const deleteBtn = document.getElementById('delete-confirm') as HTMLButtonElement;
      const deleteBtnText = document.getElementById('delete-btn-text')!;
      const deleteSpinner = document.getElementById('delete-spinner')!;
      deleteBtn.disabled = true;
      deleteBtnText.style.display = 'none';
      deleteSpinner.style.display = 'flex';

      const { error } = await supabase.from('blog_posts').delete().eq('id', deletingId);
      deleteBtn.disabled = false;
      deleteBtnText.style.display = 'inline';
      deleteSpinner.style.display = 'none';

      if (error) { showToast('Error al eliminar el artículo.', 'error'); return; }

      closeModal(deleteBackdrop);
      showToast('Artículo eliminado.');
      await loadPosts(true);
    });

    // ── Modal Helpers ─────────────────────────────────────────────
    function openModal(el: HTMLElement) { el.style.display = 'flex'; document.body.style.overflow = 'hidden'; }
    function closeModal(el: HTMLElement) { el.style.display = 'none'; document.body.style.overflow = ''; }

    document.getElementById('modal-close')!.addEventListener('click', () => closeModal(modalBackdrop));
    document.getElementById('cancel-btn')!.addEventListener('click', () => closeModal(modalBackdrop));
    document.getElementById('delete-modal-close')!.addEventListener('click', () => closeModal(deleteBackdrop));
    document.getElementById('delete-cancel')!.addEventListener('click', () => closeModal(deleteBackdrop));

    modalBackdrop.addEventListener('click', (e) => { if (e.target === modalBackdrop) closeModal(modalBackdrop); });
    deleteBackdrop.addEventListener('click', (e) => { if (e.target === deleteBackdrop) closeModal(deleteBackdrop); });

    // Init
    loadPosts();
  });
</script>
