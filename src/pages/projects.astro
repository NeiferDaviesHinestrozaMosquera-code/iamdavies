---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';
import CategoryFilters from '../components/projects/CategoryFilters.astro';
import ProjectCard from '../components/projects/ProjectCard.astro';
import ProjectModal from '../components/projects/ProjectModal.astro';
import { useTranslations } from '../i18n';

// Fetch published projects from Supabase
const { data: projects = [], error } = await supabase
  .from('projects')
  .select('*')
  .eq('status', 'published')
  .order('created_at', { ascending: false });

if (error) {
  console.error('Error fetching projects from Supabase:', error);
}

const lang = Astro.locals.lang;
const t = useTranslations(lang);

// Extract unique categories dynamically
const categories = Array.from(new Set((projects || []).map(p => p.category))).filter(Boolean);

const formatUrl = (url: string | null) => {
  if (!url) return undefined;
  const trimmed = url.trim();
  if (!trimmed) return undefined;
  if (/^(https?:\/\/|mailto:|tel:|javascript:)/i.test(trimmed)) {
    return trimmed;
  }
  return `https://${trimmed}`;
};

const listItems = (projects || []).map((p, idx) => ({
  "@type": "ListItem",
  "position": idx + 1,
  "item": {
    "@type": "CreativeWork",
    "name": p.title,
    "description": p.description,
    "url": formatUrl(p.live_url) || formatUrl(p.github_url),
    "image": p.image_url || undefined
  }
}));

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": t.projects.metaTitle,
  "description": t.projects.metaDescription,
  "numberOfItems": projects?.length || 0,
  "itemListElement": listItems
};
---

<Layout title={t.projects.metaTitle} description={t.projects.metaDescription} schema={schema}>
  <div class="starfield"></div>
  <div class="nebula-glow nebula-purple"></div>
  <div class="nebula-glow nebula-cyan"></div>

  <section class="projects-section container">
    <div class="header-content reveal">
      <h1 class="page-title"><span class="gradient-text">/</span> {t.projects.title}</h1>
      <p class="subtitle">{t.projects.subtitle}</p>
    </div>

    <!-- Category Filters -->
    <CategoryFilters categories={categories} />

    <!-- Projects Grid -->
    <div class="projects-grid">
      {projects && projects.length > 0 ? (
        projects.map((project, index) => (
          <ProjectCard project={project} index={index} />
        ))
      ) : (
        <div class="no-projects-msg glass reveal">
          <p>{t.projects.noProjects}</p>
        </div>
      )}
    </div>
  </section>

  <!-- Project Details Modal -->
  <ProjectModal lang={lang} />
</Layout>

<style>
  .projects-section {
    padding-top: 2rem;
    padding-bottom: 6rem;
    min-height: 80vh;
  }

  .header-content {
    margin-bottom: 3rem;
  }

  .page-title {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-family: var(--font-mono);
    margin-bottom: 0.75rem;
  }

  .subtitle {
    color: var(--text-secondary);
    max-width: 600px;
    font-size: 1.1rem;
    line-height: 1.6;
  }

  /* Grid layout */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2.5rem;
  }

  .no-projects-msg {
    grid-column: 1 / -1;
    text-align: center;
    padding: 4rem 2rem;
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    color: var(--text-secondary);
  }
</style>
