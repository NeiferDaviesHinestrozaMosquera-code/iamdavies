---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';
import CategoryFilters from '../components/projects/CategoryFilters.astro';
import ProjectCard from '../components/projects/ProjectCard.astro';
import ProjectModal from '../components/projects/ProjectModal.astro';

// Fetch published projects from Supabase
const { data: projects = [], error } = await supabase
  .from('projects')
  .select('*')
  .eq('status', 'published')
  .order('created_at', { ascending: false });

if (error) {
  console.error('Error fetching projects from Supabase:', error);
}

// Extract unique categories dynamically
const categories = Array.from(new Set((projects || []).map(p => p.category))).filter(Boolean);

const description = "Explora mi portafolio de proyectos de ingeniería de software, interfaces web interactivas, desarrollo frontend y diseño de producto digital.";

const listItems = (projects || []).map((p, idx) => ({
  "@type": "ListItem",
  "position": idx + 1,
  "item": {
    "@type": "CreativeWork",
    "name": p.title,
    "description": p.description,
    "url": p.live_url || p.github_url || undefined,
    "image": p.image_url || undefined
  }
}));

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Proyectos de Dev Davies",
  "description": description,
  "numberOfItems": projects?.length || 0,
  "itemListElement": listItems
};
---

<Layout title="Proyectos Creativos" description={description} schema={schema}>
  <div class="starfield"></div>
  <div class="nebula-glow nebula-purple"></div>
  <div class="nebula-glow nebula-cyan"></div>

  <section class="projects-section container">
    <div class="header-content reveal">
      <h1 class="page-title"><span class="gradient-text">/</span> Proyectos</h1>
      <p class="subtitle">Explora mi portafolio de ingeniería de software, interfaces inmersivas e identidad de marca.</p>
    </div>

    <!-- Category Filters -->
    <CategoryFilters categories={categories} />

    <!-- Projects Grid -->
    <div class="projects-grid">
      {projects && projects.length > 0 ? (
        projects.map((project, index) => (
          <ProjectCard project={project} index={index} />
        ))
      ) : (
        <div class="no-projects-msg glass reveal">
          <p>No se encontraron proyectos publicados en este momento.</p>
        </div>
      )}
    </div>
  </section>

  <!-- Project Details Modal -->
  <ProjectModal />
</Layout>

<style>
  .projects-section {
    padding-top: 2rem;
    padding-bottom: 6rem;
    min-height: 80vh;
  }

  .header-content {
    margin-bottom: 3rem;
  }

  .page-title {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-family: var(--font-mono);
    margin-bottom: 0.75rem;
  }

  .subtitle {
    color: var(--text-secondary);
    max-width: 600px;
    font-size: 1.1rem;
    line-height: 1.6;
  }

  /* Grid layout */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2.5rem;
  }

  .no-projects-msg {
    grid-column: 1 / -1;
    text-align: center;
    padding: 4rem 2rem;
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    color: var(--text-secondary);
  }
</style>
