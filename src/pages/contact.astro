---
import Layout from '../layouts/Layout.astro';
import KineticTrails from '../components/contact/KineticTrails.astro';
import FloatingShapes from '../components/contact/FloatingShapes.astro';
import ContactForm from '../components/contact/ContactForm.astro';
---

<Layout title="Contacto">
  <div class="starfield"></div>
  <div class="nebula-glow nebula-purple"></div>
  <div class="nebula-glow nebula-cyan"></div>

  <!-- Background Light Streaks -->
  <KineticTrails />

  <!-- Floating 3D Shapes -->
  <FloatingShapes />

  <section class="contact-section container">
    <div class="contact-header reveal">
      <h1 class="glow-title">GET IN TOUCH</h1>
      <p class="glow-subtitle">Let's Collaborate</p>
    </div>

    <ContactForm />
  </section>
</Layout>

<style>
  .contact-section {
    padding-top: 2rem;
    padding-bottom: 8rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 5;
  }

  .contact-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .glow-title {
    font-family: var(--font-mono);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: 0.1em;
    background: linear-gradient(135deg, #fff 40%, #a1a1aa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 0.5rem;
  }

  .glow-subtitle {
    font-size: clamp(1.1rem, 2.5vw, 1.6rem);
    color: var(--accent-cyan);
    font-family: var(--font-sans);
    font-weight: 500;
    letter-spacing: 0.05em;
    margin: 0;
    text-shadow: 0 0 15px rgba(6, 182, 212, 0.4);
  }
</style>
